@model SCIBM.Models.Examen
@using Newtonsoft.Json
@{
    ViewBag.Title = $"Calibración: {Model.NombreVersion}";
    ViewBag.Subtitle = "Defina la grilla de respuestas y el área de estampado de notas";
}

@section styles {
    <style>
        .editor-container {
            display: grid;
            grid-template-columns: 1fr 420px;
            gap: 30px;
            align-items: start;
            height: calc(100vh - 180px);
            min-height: 550px;
        }

        /* PDF VIEWER COLUMN */
        .viewer-card {
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
            padding: 16px !important;
        }
        
        .viewer-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: 12px;
        }

        .pdf-viewport-container {
            flex-grow: 1;
            overflow: auto;
            position: relative;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 20px;
        }

        .pdf-wrapper {
            position: relative;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            background: white;
            line-height: 0;
        }

        #pdf-canvas {
            display: block;
            z-index: 5;
        }

        /* OVERLAY PARA INPUTS Y STAMP */
        #overlay-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 10;
            pointer-events: auto;
        }

        /* CAJA DE ESTAMPADO DRAGGABLE & RESIZABLE */
        #stamp-box {
            position: absolute;
            border: 2px dashed #ff5252;
            background: rgba(255, 82, 82, 0.15);
            color: #ff5252;
            border-radius: 4px;
            cursor: move;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            user-select: none;
            box-sizing: border-box;
            box-shadow: 0 0 10px rgba(255, 82, 82, 0.3);
            text-transform: uppercase;
        }
        .stamp-handle {
            position: absolute;
            width: 10px;
            height: 10px;
            background: #ff5252;
            right: -5px;
            bottom: -5px;
            cursor: se-resize;
            border-radius: 50%;
        }

        /* CONTROLES DE PREGUNTA EN EL PDF */
        .question-overlay-box {
            position: absolute;
            border: 1px solid var(--accent-color);
            background: rgba(72, 202, 228, 0.08);
            border-radius: 4px;
            cursor: pointer;
            box-sizing: border-box;
            transition: background 0.2s;
        }
        .question-overlay-box:hover, .question-overlay-box.active {
            background: rgba(72, 202, 228, 0.2);
            border-width: 2px;
        }
        .question-badge-number {
            position: absolute;
            top: -10px;
            left: -10px;
            width: 20px;
            height: 20px;
            background: var(--accent-color);
            color: #0b132b;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
        }

        .option-radio-overlay {
            position: absolute;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: 2px solid #2ec4b6;
            background: rgba(46, 196, 182, 0.15);
            cursor: pointer;
            transform: translate(-50%, -50%);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .option-radio-overlay.selected {
            background: #2ec4b6;
            box-shadow: 0 0 8px #2ec4b6;
        }

        .blank-textbox-overlay {
            position: absolute;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid var(--accent-color);
            border-radius: 4px;
            outline: none;
            color: #1c2541;
            font-weight: 600;
            padding: 2px 4px;
            box-sizing: border-box;
            text-align: center;
        }

        /* QUESTIONNAIRE PANEL COLUMN */
        .panel-card {
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
        }

        .questions-list {
            flex-grow: 1;
            overflow-y: auto;
            padding-right: 5px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 20px;
        }

        .question-card-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--glass-border);
            border-radius: 8px;
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: all 0.2s;
        }
        .question-card-item.active {
            border-color: var(--accent-color);
            background: rgba(72, 202, 228, 0.04);
        }

        .q-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .q-title {
            font-weight: 600;
            font-size: 14px;
            color: var(--primary-glow);
        }

        .q-inputs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .form-select {
            width: 100%;
            padding: 8px 10px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 6px;
            color: white;
            font-size: 13px;
            outline: none;
        }
        .form-select option {
            background: var(--sidebar-bg);
            color: white;
        }

        /* LOADING DIALOG */
        .progress-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(11, 19, 43, 0.95);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 3000;
            gap: 20px;
        }
        .progress-bar {
            width: 320px;
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-color), var(--primary-glow));
            width: 0%;
            transition: width 0.3s ease;
        }

        /* CONFIRM MODAL */
        #confirm-modal {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(11, 19, 43, 0.85);
            backdrop-filter: blur(8px);
            z-index: 4000;
            display: none;
            justify-content: center;
            align-items: center;
        }
        .confirm-box {
            background: var(--sidebar-bg);
            border: 1px solid var(--glass-border);
            padding: 30px;
            border-radius: 12px;
            width: 400px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            color: white;
        }
        .confirm-box i {
            font-size: 40px;
            color: #fca311;
            margin-bottom: 15px;
        }
        .confirm-box h3 { margin-top: 0; color: white; }
        .confirm-box p { color: var(--text-muted); font-size: 14px; margin-bottom: 25px; }
        .confirm-btns { display: flex; gap: 15px; justify-content: center; }
        .btn-cancelar { background: transparent; border: 1px solid var(--text-muted); color: var(--text-muted); padding: 8px 20px; border-radius: 6px; cursor: pointer; font-size:13px; }
        .btn-cancelar:hover { background: rgba(255,255,255,0.1); }
        .btn-continuar { background: var(--accent-color); border: none; color: white; padding: 8px 20px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size:13px; }
        .btn-continuar:hover { opacity: 0.9; }

        /* TOOLBAR FLOTANTE / HERRAMIENTAS */
        .editor-toolbar {
            display: flex;
            gap: 10px;
            background: rgba(11, 19, 43, 0.85);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            padding: 8px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            margin-bottom: 15px;
            justify-content: center;
        }
        .tool-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid transparent;
            color: white;
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .tool-btn:hover {
            background: rgba(255,255,255,0.1);
        }
        .tool-btn.active {
            background: rgba(72, 202, 228, 0.2);
            border-color: var(--accent-color);
            color: var(--accent-color);
            box-shadow: 0 0 10px rgba(72, 202, 228, 0.2);
        }
        .tool-btn-danger {
            color: #ff5252;
        }
        .tool-btn-danger:hover {
            background: rgba(255, 82, 82, 0.1);
        }
        .tool-btn-danger.active {
            background: rgba(255, 82, 82, 0.2);
            border-color: #ff5252;
            box-shadow: 0 0 10px rgba(255, 82, 82, 0.2);
        }

        /* RESIZE HANDLES */
        .resize-handle {
            position: absolute;
            right: -5px;
            bottom: -5px;
            width: 10px;
            height: 10px;
            background-color: var(--accent-color);
            border-radius: 2px;
            cursor: se-resize;
            display: none; /* Se muestra solo cuando está activo */
        }
        .question-overlay-box.active .resize-handle {
            display: block;
        }
        
        .question-card-item {
            cursor: pointer;
        }
    </style>
}

<!-- EDITOR WRAPPER -->
<div class="editor-container">

    <!-- LEFT COLUMN: PDF VIEW -->
    <div class="glass-card viewer-card">
        <div class="editor-toolbar">
            <button class="tool-btn active" id="tool-mover" onclick="setTool('mover')">
                <i class="fa-solid fa-arrow-pointer"></i> Puntero
            </button>
            <button class="tool-btn" id="tool-opcion" onclick="setTool('opcion')">
                <i class="fa-regular fa-circle-dot"></i> Opción Múltiple
            </button>
            <button class="tool-btn" id="tool-texto" onclick="setTool('texto')">
                <i class="fa-solid fa-i-cursor"></i> Espacio Blanco
            </button>
            <button class="tool-btn" id="tool-vf" onclick="setTool('vf')">
                <i class="fa-solid fa-check-double"></i> Caja V/F
            </button>
            <button class="tool-btn" id="tool-vf-v" onclick="setTool('vf-v')" style="display:none; margin-left:-5px; padding-left:10px; border-left:1px solid rgba(255,255,255,0.1)">
                <i class="fa-regular fa-circle-check"></i> V
            </button>
            <button class="tool-btn" id="tool-vf-f" onclick="setTool('vf-f')" style="display:none; margin-left:-5px; padding-left:10px;">
                <i class="fa-regular fa-circle-xmark"></i> F
            </button>
            <div style="width: 1px; background: rgba(255,255,255,0.1); margin: 0 5px;"></div>
            <button class="tool-btn tool-btn-danger" id="tool-borrador" onclick="setTool('borrador')">
                <i class="fa-solid fa-eraser"></i> Borrador
            </button>
        </div>

        <div class="viewer-toolbar">
            <div style="display: flex; gap: 8px;">
                <button class="btn btn-secondary" style="padding: 8px 14px;" onclick="changePage(-1)">
                    <i class="fa-solid fa-arrow-left"></i>
                </button>
                <span id="page-num-indicator" style="font-weight: 500; font-size: 14px; display: inline-flex; align-items: center; padding: 0 10px;">
                    Cargando páginas...
                </span>
                <button class="btn btn-secondary" style="padding: 8px 14px;" onclick="changePage(1)">
                    <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
            
            <div style="display: flex; gap: 10px;">
                <!-- Manual Delete button moved to toolbar, but keeping this for quick access -->
                <button class="btn btn-danger" style="padding: 8px 14px; font-size: 13px;" onclick="deleteSelectedQuestion()" id="delete-q-btn" disabled>
                    <i class="fa-solid fa-trash-can"></i>
                </button>
            </div>
        </div>

        <div class="pdf-viewport-container">
            <div class="pdf-wrapper" id="pdf-wrapper-el">
                <canvas id="pdf-canvas"></canvas>
                <!-- OVERLAY LAYER FOR INPUTS -->
                <div id="overlay-container">
                    <!-- DRAGGABLE STAMP BOX -->
                    <div id="stamp-box">
                        Nota: 20.0
                        <div class="stamp-handle"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT COLUMN: FORM & CONFIGURATION -->
    <div class="glass-card panel-card">
        <div class="panel-header">
            <h2>Plantilla Examen</h2>
            <div style="font-size: 13px; color: var(--text-muted);">
                Total: <strong id="total-score-indicator" style="color: var(--primary-glow);">0.0 ptos</strong>
            </div>
        </div>

        <!-- LIST OF QUESTIONS -->
        <div class="questions-list" id="questions-list-el">
            <!-- Cargado dinámicamente -->
        </div>

        <!-- FOOTER ACTIONS -->
        <div style="border-top: 1px solid rgba(255, 255, 255, 0.05); padding-top: 15px; display: flex; gap: 12px; justify-content: flex-end;">
            <a href="@Url.Action("Detail", "Unidad", new { id = Model.Id })" class="btn btn-secondary">Cancelar</a>
            <button class="btn btn-primary" onclick="saveExamen()">Guardar Plantilla</button>
        </div>
    </div>

</div>

<!-- LOADING OCR DIALOG -->
<div class="progress-overlay" id="ocr-loader">
    <i class="fa-solid fa-microchip-scan" style="font-size: 64px; color: var(--primary-glow); text-shadow: 0 0 20px var(--primary-glow); animation: pulse 1.5s infiniteAlternate;"></i>
    <h3 id="ocr-loader-title">Inicializando visor de examen...</h3>
    <p id="ocr-loader-subtitle" style="color: var(--text-muted); font-size: 14.5px;">Cargando documento PDF...</p>
    <div class="progress-bar">
        <div class="progress-fill" id="ocr-progress-bar"></div>
    </div>
</div>

<!-- GLASS ALERT MODAL -->
<div class="progress-overlay" id="glass-alert-modal" style="display: none; z-index: 3000;">
    <div class="glass-card" style="max-width: 400px; text-align: center; padding: 30px; animation: slideUp 0.3s ease-out;">
        <i id="alert-icon" class="fa-solid fa-triangle-exclamation" style="font-size: 48px; color: #ff5252; margin-bottom: 15px;"></i>
        <h3 id="alert-title" style="margin-bottom: 10px; color: white;">Atención</h3>
        <p id="alert-message" style="color: var(--text-muted); font-size: 14px; margin-bottom: 20px;">Mensaje de error.</p>
        <button class="btn btn-primary" onclick="closeAlertModal()" style="width: 100%;">Entendido</button>
    </div>
    </div>

    <!-- Confirm Modal -->
    <div id="confirm-modal">
        <div class="confirm-box">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <h3>¿Cambiar configuración?</h3>
            <p>¿Seguro que desea quitar las subpreguntas? Se quedará solo con la primera opción registrada y lo demás se limpiará.</p>
            <div class="confirm-btns">
                <button class="btn-cancelar" onclick="cancelConfirmToggle()">Cancelar</button>
                <button class="btn-continuar" onclick="proceedConfirmToggle()">Continuar</button>
            </div>
        </div>
    </div>

@section Scripts {
    <!-- PDF.js y Tesseract.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@4.0.2/dist/tesseract.min.js"></script>

    <script>
        // Configuración de PDF.js
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';

        var pdfDoc = null;
        var currentPageNum = 1;
        var totalPages = 1;
        var pdfScale = 1.2;
        var canvas = document.getElementById("pdf-canvas");
        var ctx = canvas.getContext("2d");
        var wrapper = document.getElementById("pdf-wrapper-el");
        var overlay = document.getElementById("overlay-container");

        // Datos del modelo
        var examenId = '@Model.Id';
        @{
            string fileName = Model.RutaPdfOriginal != null ? Model.RutaPdfOriginal.Substring(Model.RutaPdfOriginal.LastIndexOf("/") + 1) : "";
        }
        var pdfUrl = '@Url.Action("GetExamenPdf", "Examen", new { filename = fileName })';
        
        // Listado de preguntas en memoria
        var preguntas = [];
        var activeQuestionIndex = -1;

        // Coordenadas de estampado inicial (porcentajes)
        var stampX = @Model.StampX.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var stampY = @Model.StampY.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var stampWidth = @Model.StampWidth.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var stampHeight = @Model.StampHeight.ToString(System.Globalization.CultureInfo.InvariantCulture);

        // Inicializar
        window.addEventListener('load', function() {
            cargarPdf();
            initDraggableStamp();
        });

        // 1. Cargar el PDF original
        function cargarPdf() {
            var loader = document.getElementById("ocr-loader");
            var loaderTitle = document.getElementById("ocr-loader-title");
            var fill = document.getElementById("ocr-progress-bar");

            loaderTitle.innerText = "Cargando documento PDF...";
            fill.style.width = "20%";

            pdfjsLib.getDocument(pdfUrl).promise.then(function(pdfDoc_) {
                pdfDoc = pdfDoc_;
                totalPages = pdfDoc.numPages;
                fill.style.width = "50%";
                
                // Cargar datos preexistentes si los hay
                cargarPreguntasExistentes();

                // Si no hay preguntas guardadas, realizamos el OCR inicial de la primera página
                if (preguntas.length === 0) {
                    ejecutarOcrInicial();
                } else {
                    renderPage(currentPageNum);
                    loader.style.display = "none";
                }
            }).catch(function(err) {
                alert("Error al cargar PDF: " + err.message);
                loader.style.display = "none";
            });
        }

        // Cargar preguntas guardadas en la base de datos
        function cargarPreguntasExistentes() {
            @if (Model.Preguntas != null && Model.Preguntas.Any())
            {
                foreach (var p in Model.Preguntas.OrderBy(pr => pr.NumeroPregunta))
                {
                    <text>
                    preguntas.push({
                        id: '@p.Id',
                        numeroPregunta: @p.NumeroPregunta,
                        enunciado: @Html.Raw(JsonConvert.SerializeObject(p.Enunciado)),
                        tipo: @Html.Raw(JsonConvert.SerializeObject(p.Tipo)),
                        respuestaCorrecta: @Html.Raw(JsonConvert.SerializeObject(p.RespuestaCorrecta)),
                        puntaje: @p.Puntaje.ToString(System.Globalization.CultureInfo.InvariantCulture),
                        posX: @p.PosX.ToString(System.Globalization.CultureInfo.InvariantCulture),
                        posY: @p.PosY.ToString(System.Globalization.CultureInfo.InvariantCulture),
                        width: @p.Width.ToString(System.Globalization.CultureInfo.InvariantCulture),
                        height: @p.Height.ToString(System.Globalization.CultureInfo.InvariantCulture),
                        opcionesJson: @Html.Raw(string.IsNullOrEmpty(p.OpcionesJson) ? "[]" : JsonConvert.SerializeObject(p.OpcionesJson)),
                        page: 1 // Por defecto en página 1
                    });
                    </text>
                }
            }
            recalcularPuntajeTotal();
        }

        // Estado del editor visual
        var currentTool = 'mover';

        function setTool(toolName) {
            currentTool = toolName;
            document.querySelectorAll('.tool-btn').forEach(btn => btn.classList.remove('active'));
            
            if (toolName.startsWith('vf')) {
                document.getElementById('tool-vf').classList.add('active');
                document.getElementById('tool-vf-v').style.display = 'inline-block';
                document.getElementById('tool-vf-f').style.display = 'inline-block';
            } else {
                var vBtn = document.getElementById('tool-vf-v');
                var fBtn = document.getElementById('tool-vf-f');
                if (vBtn) vBtn.style.display = 'none';
                if (fBtn) fBtn.style.display = 'none';
            }

            var btn = document.getElementById('tool-' + toolName);
            if (btn) btn.classList.add('active');

            if (toolName === 'texto' || toolName === 'opcion' || toolName.startsWith('vf')) {
                overlay.style.cursor = 'crosshair';
            } else if (toolName === 'borrador') {
                overlay.style.cursor = 'url(https://cdn-icons-png.flaticon.com/32/2723/2723376.png) 0 32, auto';
            } else {
                overlay.style.cursor = 'default';
            }
        }

        // Lógica Click-to-Drop en el Canvas (Overlay)
        overlay.addEventListener('mousedown', function(e) {
            // Ignorar clics si no se hizo en el overlay directamente (ej. si se hizo clic en una pregunta existente)
            if (e.target !== overlay) return;

            if (currentTool === 'mover' || currentTool === 'borrador') return;

            var rect = overlay.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;

            var px = (x / rect.width) * 100.0;
            var py = (y / rect.height) * 100.0;

            var qNum = preguntas.length > 0 ? Math.max(...preguntas.map(p => p.numeroPregunta)) + 1 : 1;

            if (currentTool === 'texto') {
                preguntas.push({
                    id: null,
                    numeroPregunta: qNum,
                    enunciado: "Pregunta Abierta " + qNum,
                    tipo: "RespuestaLibre",
                    respuestaCorrecta: "Texto",
                    puntaje: 1.0,
                    posX: px,
                    posY: py,
                    width: 30,
                    height: 5,
                    opcionesJson: "[]",
                    tieneSubpreguntas: false,
                    page: currentPageNum
                });
            } else if (currentTool === 'opcion') {
                preguntas.push({
                    id: null,
                    numeroPregunta: qNum,
                    enunciado: "Opción Múltiple " + qNum,
                    tipo: "OpcionMultiple",
                    respuestaCorrecta: "A",
                    puntaje: 1.0,
                    posX: px,
                    posY: py,
                    width: 30,
                    height: 6,
                    opcionesJson: "[]",
                    tieneSubpreguntas: false,
                    page: currentPageNum
                });
            } else if (currentTool === 'vf') {
                preguntas.push({
                    id: null,
                    numeroPregunta: qNum,
                    enunciado: "Verdadero/Falso " + qNum,
                    tipo: "VerdaderoFalso",
                    respuestaCorrecta: "",
                    puntaje: 0,
                    posX: px,
                    posY: py,
                    width: 30,
                    height: 10,
                    opcionesJson: "[]",
                    tieneSubpreguntas: false,
                    page: currentPageNum
                });
            }

            preguntas.sort((a, b) => a.numeroPregunta - b.numeroPregunta);
            recalcularPuntajeTotal();
            renderOverlayControls();
            renderQuestionsForm();
            
            // Ya no forzamos setTool('mover') para permitir clics múltiples rápidos
            // (Ej: dibujar la caja, y de inmediato hacer clic adentro para las opciones)
        });

        // 2. Ejecutar Escaneo Inicial con Gemini Vision API
        async function ejecutarOcrInicial() {
            var loader = document.getElementById("ocr-loader");
            var loaderTitle = document.getElementById("ocr-loader-title");
            var loaderSubtitle = document.getElementById("ocr-loader-subtitle");
            var fill = document.getElementById("ocr-progress-bar");

            loaderTitle.innerText = "Analizando estructura con IA...";
            loaderSubtitle.innerText = "Gemini Vision está leyendo el PDF...";
            fill.style.width = "40%";

            try {
                var formData = new FormData();
                formData.append('examenId', examenId);

                var response = await fetch('@Url.Action("ScanTemplateWithGemini", "Examen")', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) throw new Error("Error HTTP " + response.status);
                var data = await response.json();

                fill.style.width = "90%";

                if (data && data.preguntas && data.preguntas.length > 0) {
                    data.preguntas.forEach(pq => {
                        preguntas.push({
                            id: null,
                            numeroPregunta: pq.numeroPregunta,
                            enunciado: pq.enunciado || "Pregunta " + pq.numeroPregunta,
                            tipo: pq.tipo || "OpcionMultiple",
                            respuestaCorrecta: (pq.tipo === "RespuestaLibre") ? "Texto" : (pq.opciones && pq.opciones.length > 0 ? pq.opciones[0].label : "A"),
                            puntaje: 1.0,
                            posX: pq.posX || 10,
                            posY: pq.posY || 10,
                            width: pq.width || 30,
                            height: pq.height || 6,
                            opcionesJson: JSON.stringify(pq.opciones || []),
                            page: 1
                        });
                    });
                } else {
                    // Si Gemini falló o no vio nada, instanciar una por defecto
                    preguntas.push({
                        id: null,
                        numeroPregunta: 1,
                        enunciado: "Pregunta 1",
                        tipo: "OpcionMultiple",
                        respuestaCorrecta: "A",
                        puntaje: 2.0,
                        posX: 10, posY: 15, width: 70, height: 6,
                        opcionesJson: JSON.stringify([
                            { label: "A", x: 12, y: 22, w: 2.5, h: 2.5 },
                            { label: "B", x: 17, y: 22, w: 2.5, h: 2.5 },
                            { label: "C", x: 22, y: 22, w: 2.5, h: 2.5 },
                            { label: "D", x: 27, y: 22, w: 2.5, h: 2.5 },
                            { label: "E", x: 32, y: 22, w: 2.5, h: 2.5 }
                        ]),
                        page: 1
                    });
                }

                preguntas.sort((a, b) => a.numeroPregunta - b.numeroPregunta);
                recalcularPuntajeTotal();
                renderPage(1);
                loader.style.display = "none";
            } catch (err) {
                console.error("Error al usar Gemini:", err);
                loaderTitle.innerText = "Error de IA";
                loaderSubtitle.innerText = "Hubo un problema de red. Pasando al modo manual.";
                setTimeout(() => {
                    loader.style.display = "none";
                    renderPage(1);
                }, 3000);
            }
        }

        // 3. Renderizar la página PDF en el canvas
        function renderPage(pageNum) {
            currentPageNum = pageNum;
            document.getElementById("page-num-indicator").innerText = `Pág. ${pageNum} de ${totalPages}`;

            pdfDoc.getPage(pageNum).then(function(page) {
                var viewport = page.getViewport({ scale: pdfScale });
                canvas.width = viewport.width;
                canvas.height = viewport.height;

                var renderContext = {
                    canvasContext: ctx,
                    viewport: viewport
                };

                page.render(renderContext).promise.then(function() {
                    // Adaptar las dimensiones del contenedor overlay
                    overlay.style.width = viewport.width + "px";
                    overlay.style.height = viewport.height + "px";
                    wrapper.style.width = viewport.width + "px";
                    wrapper.style.height = viewport.height + "px";

                    // Posicionar la caja de estampado en base a porcentajes guardados
                    positionStampBox();

                    // Renderizar los controles sobre el PDF
                    renderOverlayControls();

                    // Renderizar el formulario del panel lateral derecho
                    renderQuestionsForm();
                });
            });
        }

        function changePage(delta) {
            var newPage = currentPageNum + delta;
            if (newPage >= 1 && newPage <= totalPages) {
                renderPage(newPage);
            }
        }

        // 4. Posicionar la caja de estampado
        function positionStampBox() {
            var box = document.getElementById("stamp-box");
            box.style.left = stampX + "%";
            box.style.top = stampY + "%";
            box.style.width = stampWidth + "%";
            box.style.height = stampHeight + "%";
        }

        // 5. Inicializar la lógica Draggable & Resizable de la caja de estampado
        function initDraggableStamp() {
            var box = document.getElementById("stamp-box");
            var handle = box.querySelector(".stamp-handle");
            var isDragging = false;
            var isResizing = false;
            var startX, startY, startLeft, startTop, startWidth, startHeight;

            box.addEventListener('mousedown', function(e) {
                if (e.target === handle) return; // Si hace click en el handle de redimensionar
                isDragging = true;
                startX = e.clientX;
                startY = e.clientY;
                startLeft = box.offsetLeft;
                startTop = box.offsetTop;
                e.preventDefault();
            });

            handle.addEventListener('mousedown', function(e) {
                isResizing = true;
                startX = e.clientX;
                startY = e.clientY;
                startWidth = box.offsetWidth;
                startHeight = box.offsetHeight;
                e.preventDefault();
                e.stopPropagation();
            });

            document.addEventListener('mousemove', function(e) {
                var overlayW = overlay.offsetWidth;
                var overlayH = overlay.offsetHeight;

                if (isDragging) {
                    var dx = e.clientX - startX;
                    var dy = e.clientY - startY;
                    var newLeft = startLeft + dx;
                    var newTop = startTop + dy;

                    // Limitar bordes
                    if (newLeft < 0) newLeft = 0;
                    if (newTop < 0) newTop = 0;
                    if (newLeft + box.offsetWidth > overlayW) newLeft = overlayW - box.offsetWidth;
                    if (newTop + box.offsetHeight > overlayH) newTop = overlayH - box.offsetHeight;

                    // Convertir a porcentajes
                    stampX = (newLeft / overlayW) * 100.0;
                    stampY = (newTop / overlayH) * 100.0;
                    
                    positionStampBox();
                }

                if (isResizing) {
                    var dx = e.clientX - startX;
                    var dy = e.clientY - startY;
                    var newW = startWidth + dx;
                    var newH = startHeight + dy;

                    // Limitar tamaño mínimo
                    if (newW < 60) newW = 60;
                    if (newH < 25) newH = 25;
                    if (box.offsetLeft + newW > overlayW) newW = overlayW - box.offsetLeft;
                    if (box.offsetTop + newH > overlayH) newH = overlayH - box.offsetTop;

                    // Convertir a porcentajes
                    stampWidth = (newW / overlayW) * 100.0;
                    stampHeight = (newH / overlayH) * 100.0;

                    positionStampBox();
                }
            });

            document.addEventListener('mouseup', function() {
                isDragging = false;
                isResizing = false;
            });
        }

        // 6. Renderizar controles visuales sobre la capa overlay del PDF
        function renderOverlayControls() {
            // Eliminar controles anteriores excepto la caja de estampado
            var elements = overlay.querySelectorAll(".question-overlay-box, .option-radio-overlay, .blank-textbox-overlay");
            elements.forEach(el => el.remove());

            var overlayW = overlay.offsetWidth;
            var overlayH = overlay.offsetHeight;

            preguntas.forEach((p, idx) => {
                if (p.page !== currentPageNum) return;

                // 1. Contenedor de la pregunta (caja azul semitransparente)
                var box = document.createElement("div");
                box.className = "question-overlay-box" + (activeQuestionIndex === idx ? " active" : "");
                box.style.left = p.posX + "%";
                box.style.top = p.posY + "%";
                box.style.width = p.width + "%";
                box.style.height = p.height + "%";

                var numBadge = document.createElement("div");
                numBadge.className = "question-badge-number";
                numBadge.innerText = p.numeroPregunta;
                box.appendChild(numBadge);

                // Resize handle solo para la caja principal
                var rHandle = document.createElement("div");
                rHandle.className = "resize-handle";
                box.appendChild(rHandle);

                box.onclick = function(e) {
                    if (currentTool === 'borrador') {
                        preguntas.splice(idx, 1);
                        activeQuestionIndex = -1;
                        recalcularPuntajeTotal();
                        renderOverlayControls();
                        renderQuestionsForm();
                        e.stopPropagation();
                        return;
                    }

                    // Punto 1: Clic dinámico para crear opciones dentro de la caja
                    if (activeQuestionIndex === idx) {
                        if (currentTool === 'opcion' && p.tipo === "OpcionMultiple") {
                            var rect = overlay.getBoundingClientRect();
                            var px = ((e.clientX - rect.left) / rect.width) * 100.0;
                            var py = ((e.clientY - rect.top) / rect.height) * 100.0;

                            var opciones = [];
                            try { opciones = JSON.parse(p.opcionesJson) || []; } catch(ex){}
                            
                            // Letras secuenciales: 65 = 'A', 66 = 'B'...
                            var nextChar = String.fromCharCode(65 + opciones.length); 
                            
                            opciones.push({ label: nextChar, x: px, y: py, w: 2.5, h: 2.5 });
                            p.opcionesJson = JSON.stringify(opciones);
                            
                            if (opciones.length === 1) {
                                p.respuestaCorrecta = nextChar;
                            }

                            renderOverlayControls();
                            renderQuestionsForm();
                            e.stopPropagation();
                            return;
                        }

                        // Punto 2: Clic dinámico para incisos V/F
                        if ((currentTool === 'vf-v' || currentTool === 'vf-f') && p.tipo === "VerdaderoFalso") {
                            var rect = overlay.getBoundingClientRect();
                            var px = ((e.clientX - rect.left) / rect.width) * 100.0;
                            var py = ((e.clientY - rect.top) / rect.height) * 100.0;

                            var opciones = [];
                            try { opciones = JSON.parse(p.opcionesJson) || []; } catch(ex){}
                            
                            var nextChar = String.fromCharCode(97 + opciones.length); // 97 = 'a'
                            var val = currentTool === 'vf-v' ? 'V' : 'F';
                            
                            opciones.push({ label: nextChar, val: val, x: px, y: py, w: 2.5, h: 2.5 });
                            p.opcionesJson = JSON.stringify(opciones);
                            
                            renderOverlayControls();
                            renderQuestionsForm();
                            e.stopPropagation();
                            return;
                        }
                    }

                    selectQuestion(idx);
                    e.stopPropagation();
                };

                // Permitir arrastrar/mover y redimensionar la caja
                makeElementDraggableAndResizable(box, rHandle, idx);

                overlay.appendChild(box);

                // 2. Renderizar sub-elementos de respuesta según tipo
                if ((p.tipo === "OpcionMultiple" || p.tipo === "VerdaderoFalso") && p.opcionesJson) {
                    try {
                        var opciones = JSON.parse(p.opcionesJson);
                        opciones.forEach((opt, optIdx) => {
                            var radio = document.createElement("div");
                            
                            if (p.tipo === "VerdaderoFalso") {
                                radio.className = "option-radio-overlay selected";
                                radio.style.left = opt.x + "%";
                                radio.style.top = opt.y + "%";
                                radio.innerText = opt.label + " (" + opt.val + ")";
                                radio.style.fontSize = "8px";
                                radio.style.width = "auto";
                                radio.style.padding = "0 4px";
                                radio.style.borderRadius = "4px";
                                radio.style.color = "#0b132b";
                                radio.style.whiteSpace = "nowrap";

                                radio.onclick = function(e) {
                                    if (currentTool === 'borrador') {
                                        opciones.splice(optIdx, 1);
                                        // Reordenar a, b, c
                                        opciones.forEach((o, i) => { o.label = String.fromCharCode(97 + i); });
                                        p.opcionesJson = JSON.stringify(opciones);
                                        renderOverlayControls();
                                        renderQuestionsForm();
                                        e.stopPropagation();
                                        return;
                                    }
                                    e.stopPropagation();
                                };
                            } else {
                                radio.className = "option-radio-overlay" + (p.respuestaCorrecta === opt.label ? " selected" : "");
                                radio.style.left = opt.x + "%";
                                radio.style.top = opt.y + "%";
                                radio.innerText = opt.label;
                                radio.style.fontSize = "9px";
                                radio.style.fontWeight = "bold";
                                radio.style.color = p.respuestaCorrecta === opt.label ? "#0b132b" : "#2ec4b6";

                                radio.onclick = function(e) {
                                    if (currentTool === 'borrador') {
                                        // Borrar la opción y reordenar las letras para evitar huecos (A, C, D -> A, B, C)
                                        opciones.splice(optIdx, 1);
                                        opciones.forEach((o, i) => { o.label = String.fromCharCode(65 + i); });
                                        p.opcionesJson = JSON.stringify(opciones);
                                        
                                        // Si borró la respuesta correcta, asignar la nueva A (si existe)
                                        if (!opciones.some(o => o.label === p.respuestaCorrecta)) {
                                            p.respuestaCorrecta = opciones.length > 0 ? opciones[0].label : "";
                                        }
                                        
                                        renderOverlayControls();
                                        renderQuestionsForm();
                                        e.stopPropagation();
                                        return;
                                    }
                                    p.respuestaCorrecta = opt.label;
                                    renderOverlayControls();
                                    renderQuestionsForm();
                                    e.stopPropagation();
                                };
                            }

                            // Permitir mover la sub-opción
                            makeSubOptionDraggable(radio, idx, optIdx);

                            overlay.appendChild(radio);
                        });
                    } catch (ex) {}
                } else if (p.tipo === "RespuestaLibre") {
                    var textbox = document.createElement("div");
                    textbox.className = "blank-textbox-overlay";
                    textbox.style.left = "0";
                    textbox.style.top = "100%";
                    textbox.style.width = "100%";
                    textbox.style.height = "25px";
                    textbox.style.position = "absolute";
                    textbox.style.backgroundColor = "rgba(72, 202, 228, 0.15)";
                    textbox.style.border = "1px dashed var(--accent-color)";
                    textbox.style.borderRadius = "4px";
                    textbox.style.textAlign = "center";
                    textbox.style.cursor = "text";
                    textbox.style.marginTop = "2px";
                    textbox.style.overflow = "hidden";
                    textbox.innerText = p.respuestaCorrecta || "Texto";
                    textbox.style.fontSize = "11px";
                    textbox.style.fontWeight = "bold";
                    textbox.style.lineHeight = "25px";
                    textbox.style.color = "var(--text-color)";

                    // Evitar que el drag de la caja padre interrumpa el doble clic
                    textbox.onmousedown = function(e) {
                        if (currentTool === 'mover') {
                            e.stopPropagation();
                        }
                    };

                    textbox.ondblclick = function(e) {
                        if (currentTool === 'borrador') {
                            preguntas.splice(idx, 1);
                            activeQuestionIndex = -1;
                            recalcularPuntajeTotal();
                            renderOverlayControls();
                            renderQuestionsForm();
                            e.stopPropagation();
                            return;
                        }
                        
                        var currentVal = (p.respuestaCorrecta === "Texto" || p.respuestaCorrecta === "OK") ? "" : p.respuestaCorrecta;
                        textbox.innerText = "";
                        
                        var inputEl = document.createElement("input");
                        inputEl.type = "text";
                        inputEl.value = currentVal;
                        inputEl.style.width = "100%";
                        inputEl.style.height = "100%";
                        inputEl.style.background = "var(--bg-color)";
                        inputEl.style.color = "var(--text-color)";
                        inputEl.style.border = "none";
                        inputEl.style.outline = "none";
                        inputEl.style.textAlign = "center";
                        inputEl.style.fontSize = "12px";
                        inputEl.style.fontWeight = "bold";
                        
                        textbox.appendChild(inputEl);
                        inputEl.focus();

                        function saveText() {
                            var val = inputEl.value.trim();
                            p.respuestaCorrecta = val === "" ? "Texto" : val;
                            renderOverlayControls();
                            renderQuestionsForm();
                        }

                        inputEl.onblur = saveText;
                        inputEl.onkeypress = function(ev) {
                            if (ev.key === "Enter") saveText();
                        };

                        e.stopPropagation();
                    };

                    box.appendChild(textbox);
                }
            });
        }

        // Hacer que las cajas de preguntas sean arrastrables y redimensionables
        function makeElementDraggableAndResizable(el, handle, qIdx) {
            var isMoving = false;
            var isResizing = false;
            var sX, sY, sLeft, sTop, sWidth, sHeight;

            el.addEventListener('mousedown', function(e) {
                if (currentTool === 'borrador') return;
                if (e.target === handle || e.target.className === "question-badge-number") return;
                isMoving = true;
                sX = e.clientX;
                sY = e.clientY;
                sLeft = el.offsetLeft;
                sTop = el.offsetTop;
                selectQuestion(qIdx);
                e.preventDefault();
                e.stopPropagation();
            });

            handle.addEventListener('mousedown', function(e) {
                if (currentTool === 'borrador') return;
                isResizing = true;
                sX = e.clientX;
                sY = e.clientY;
                sWidth = el.offsetWidth;
                sHeight = el.offsetHeight;
                selectQuestion(qIdx);
                e.preventDefault();
                e.stopPropagation();
            });

            document.addEventListener('mousemove', function(e) {
                if (!isMoving && !isResizing) return;
                var dx = e.clientX - sX;
                var dy = e.clientY - sY;
                var overlayW = overlay.offsetWidth;
                var overlayH = overlay.offsetHeight;
                var p = preguntas[qIdx];

                if (isMoving) {
                    var newL = sLeft + dx;
                    var newT = sTop + dy;

                    if (newL < 0) newL = 0;
                    if (newT < 0) newT = 0;
                    if (newL + el.offsetWidth > overlayW) newL = overlayW - el.offsetWidth;
                    if (newT + el.offsetHeight > overlayH) newT = overlayH - el.offsetHeight;

                    var oldPosX = p.posX;
                    var oldPosY = p.posY;
                    p.posX = (newL / overlayW) * 100.0;
                    p.posY = (newT / overlayH) * 100.0;

                    if ((p.tipo === "OpcionMultiple" || p.tipo === "VerdaderoFalso") && p.opcionesJson) {
                        try {
                            var opciones = JSON.parse(p.opcionesJson);
                            var diffX = p.posX - oldPosX;
                            var diffY = p.posY - oldPosY;
                            opciones.forEach(opt => {
                                opt.x += diffX;
                                opt.y += diffY;
                            });
                            p.opcionesJson = JSON.stringify(opciones);
                        } catch (ex) {}
                    }

                    el.style.left = p.posX + "%";
                    el.style.top = p.posY + "%";

                    // Solo actualizar radio buttons visuales instantáneamente
                    var radios = overlay.querySelectorAll('.option-radio-overlay');
                    radios.forEach(r => r.remove()); // Hack sucio temporal, se re-renderizan en mouseup
                }

                if (isResizing) {
                    var newW = sWidth + dx;
                    var newH = sHeight + dy;
                    if (newW < 20) newW = 20;
                    if (newH < 15) newH = 15;
                    if (el.offsetLeft + newW > overlayW) newW = overlayW - el.offsetLeft;
                    if (el.offsetTop + newH > overlayH) newH = overlayH - el.offsetTop;

                    p.width = (newW / overlayW) * 100.0;
                    p.height = (newH / overlayH) * 100.0;

                    el.style.width = p.width + "%";
                    el.style.height = p.height + "%";
                }
            });

            document.addEventListener('mouseup', function(e) {
                if (isMoving || isResizing) {
                    isMoving = false;
                    isResizing = false;
                    renderOverlayControls();
                }
            });
        }

        // Permitir arrastrar los radio buttons individuales
        function makeSubOptionDraggable(el, qIdx, optIdx) {
            var isMoving = false;
            var sX, sY, sLeft, sTop;

            el.addEventListener('mousedown', function(e) {
                isMoving = true;
                sX = e.clientX;
                sY = e.clientY;
                sLeft = el.offsetLeft + (el.offsetWidth/2); // centro
                sTop = el.offsetTop + (el.offsetHeight/2); // centro
                e.preventDefault();
                e.stopPropagation();
            });

            document.addEventListener('mousemove', function(e) {
                if (!isMoving) return;
                var dx = e.clientX - sX;
                var dy = e.clientY - sY;
                var overlayW = overlay.offsetWidth;
                var overlayH = overlay.offsetHeight;

                var newL = sLeft + dx;
                var newT = sTop + dy;

                var p = preguntas[qIdx];
                try {
                    var opciones = JSON.parse(p.opcionesJson);
                    opciones[optIdx].x = (newL / overlayW) * 100.0;
                    opciones[optIdx].y = (newT / overlayH) * 100.0;
                    p.opcionesJson = JSON.stringify(opciones);
                } catch (ex) {}

                el.style.left = ((newL / overlayW) * 100.0) + "%";
                el.style.top = ((newT / overlayH) * 100.0) + "%";
            });

            document.addEventListener('mouseup', function(e) {
                if (isMoving) {
                    isMoving = false;
                    renderOverlayControls();
                }
            });
        }

        // 7. Renderizar panel lateral de preguntas
        function renderQuestionsForm() {
            var container = document.getElementById("questions-list-el");
            container.innerHTML = "";

            preguntas.forEach((p, idx) => {
                var card = document.createElement("div");
                card.className = "question-card-item" + (activeQuestionIndex === idx ? " active" : "");
                
                // Header
                var qH = document.createElement("div");
                qH.className = "q-header";
                qH.innerHTML = `<span class="q-title">Pregunta ${p.numeroPregunta}</span>
                                <span style="font-size:12px; color:var(--accent-color); font-weight:bold;">${p.puntaje.toFixed(1)} ptos</span>`;
                card.appendChild(qH);

                // Enunciado
                var label = document.createElement("div");
                label.style.fontSize = "13px";
                label.style.color = "var(--text-muted)";
                label.style.wordBreak = "break-word";
                label.innerText = p.enunciado.substring(0, 100) + (p.enunciado.length > 100 ? "..." : "");
                card.appendChild(label);

                // Inputs
                var inputsDiv = document.createElement("div");
                inputsDiv.className = "q-inputs";

                // Tipo Selector
                var selectTipo = document.createElement("select");
                selectTipo.className = "form-select";
                selectTipo.innerHTML = `<option value="OpcionMultiple" ${p.tipo === "OpcionMultiple" ? "selected" : ""}>Opción Múltiple</option>
                                        <option value="VerdaderoFalso" ${p.tipo === "VerdaderoFalso" ? "selected" : ""}>Verdadero/Falso Múltiple</option>
                                        <option value="RespuestaLibre" ${p.tipo === "RespuestaLibre" ? "selected" : ""}>Espacio Blanco</option>`;
                selectTipo.onchange = function() {
                    p.tipo = this.value;
                    if (p.tipo === "OpcionMultiple") {
                        p.respuestaCorrecta = "A";
                        p.opcionesJson = "[]";
                    } else {
                        p.respuestaCorrecta = "OK";
                        p.opcionesJson = "[]";
                    }
                    renderOverlayControls();
                    renderQuestionsForm();
                };
                inputsDiv.appendChild(selectTipo);

                // Respuesta Correcta Input
                if (p.tipo === "OpcionMultiple") {
                    var selectResp = document.createElement("select");
                    selectResp.className = "form-select";
                    
                    var opcionesArr = [];
                    try { opcionesArr = JSON.parse(p.opcionesJson) || []; } catch(e){}
                    
                    var html = "";
                    opcionesArr.forEach(l => {
                        html += `<option value="${l.label}" ${p.respuestaCorrecta === l.label ? "selected" : ""}>Opción ${l.label}</option>`;
                    });
                    if (opcionesArr.length === 0) html = `<option value="">(Vacío)</option>`;
                    
                    selectResp.innerHTML = html;
                    selectResp.onchange = function() {
                        p.respuestaCorrecta = this.value;
                        renderOverlayControls();
                    };
                    inputsDiv.appendChild(selectResp);
                } else if (p.tipo === "VerdaderoFalso") {
                    var subqDiv = document.createElement("div");
                    subqDiv.style.gridColumn = "1 / -1";
                    subqDiv.style.fontSize = "12px";
                    subqDiv.style.background = "rgba(0,0,0,0.2)";
                    subqDiv.style.padding = "8px";
                    subqDiv.style.borderRadius = "4px";
                    
                    var opcionesArr = [];
                    try { opcionesArr = JSON.parse(p.opcionesJson) || []; } catch(e){}
                    
                    var subHtml = "<strong style='color:var(--accent-color);'>Incisos Creados:</strong><ul style='margin:5px 0 0 20px; padding:0;'>";
                    opcionesArr.forEach(l => {
                        subHtml += `<li>Inciso <b>${l.label}</b>: Correcta es <b style='color:#fff'>${l.val}</b></li>`;
                    });
                    if(opcionesArr.length === 0) subHtml += "<li>(Usa las herramientas V o F para crear incisos)</li>";
                    subHtml += "</ul>";
                    
                    subqDiv.innerHTML = subHtml;
                    inputsDiv.appendChild(subqDiv);
                } else {
                    var inputText = document.createElement("input");
                    inputText.type = "text";
                    inputText.className = "form-input";
                    inputText.style.padding = "6px 10px";
                    inputText.style.fontSize = "13px";
                    inputText.value = p.respuestaCorrecta;
                    inputText.placeholder = "Respuesta Correcta";
                    inputText.oninput = function() {
                        p.respuestaCorrecta = this.value;
                        var tb = overlay.querySelector(".blank-textbox-overlay");
                        if (tb) tb.innerText = this.value;
                    };
                    inputsDiv.appendChild(inputText);
                }

                // Toggle de Subpreguntas
                var toggleDiv = document.createElement("div");
                toggleDiv.style.gridColumn = "1 / -1";
                toggleDiv.style.marginTop = "5px";
                toggleDiv.style.display = "flex";
                toggleDiv.style.alignItems = "center";
                toggleDiv.style.gap = "8px";
                
                var chkSub = document.createElement("input");
                chkSub.type = "checkbox";
                chkSub.id = "chk-sub-" + idx;
                chkSub.checked = p.tieneSubpreguntas === true;
                chkSub.onchange = function() {
                    var isChecking = this.checked;
                    if (!isChecking) {
                        var opcionesArr = [];
                        try { opcionesArr = JSON.parse(p.opcionesJson) || []; } catch(e){}
                        if (opcionesArr.length > 1) {
                            // Revert check visualmente hasta confirmar
                            this.checked = true;
                            pendingToggleQuestion = p;
                            document.getElementById("confirm-modal").style.display = "flex";
                            return;
                        }
                    }
                    p.tieneSubpreguntas = isChecking;
                    renderOverlayControls();
                    renderQuestionsForm();
                };
                
                var lblSub = document.createElement("label");
                lblSub.htmlFor = "chk-sub-" + idx;
                lblSub.innerText = "¿Contiene subpreguntas (incisos)?";
                lblSub.style.fontSize = "12px";
                lblSub.style.color = "var(--text-muted)";
                lblSub.style.cursor = "pointer";
                
                toggleDiv.appendChild(chkSub);
                toggleDiv.appendChild(lblSub);
                inputsDiv.appendChild(toggleDiv);

                card.appendChild(inputsDiv);

                card.onclick = function() {
                    selectQuestion(idx);
                };

                container.appendChild(card);
            });
        }

        function selectQuestion(idx) {
            activeQuestionIndex = idx;
            document.getElementById("delete-q-btn").disabled = (idx === -1);
            
            // Renderizar estados activos
            var items = document.querySelectorAll(".question-card-item");
            items.forEach((item, i) => {
                if (i === idx) item.classList.add("active");
                else item.classList.remove("active");
            });

            var boxes = document.querySelectorAll(".question-overlay-box");
            boxes.forEach((box, i) => {
                // Filtramos por página
                var filteredIndex = preguntas.filter(p => p.page === currentPageNum).indexOf(preguntas[idx]);
                if (filteredIndex === i) box.classList.add("active");
                else box.classList.remove("active");
            });
        }

        // Recalcular el puntaje total del examen
        function recalcularPuntajeTotal() {
            var total = preguntas.reduce((sum, p) => sum + p.Puntaje, 0);
            document.getElementById("total-score-indicator").innerText = total.toFixed(1) + " ptos";
        }

        // Lógica Global Modal Confirmación Toggle
        var pendingToggleQuestion = null;

        function cancelConfirmToggle() {
            pendingToggleQuestion = null;
            document.getElementById("confirm-modal").style.display = "none";
        }

        function proceedConfirmToggle() {
            if (pendingToggleQuestion) {
                pendingToggleQuestion.tieneSubpreguntas = false;
                var opcionesArr = [];
                try { opcionesArr = JSON.parse(pendingToggleQuestion.opcionesJson) || []; } catch(e){}
                
                if (opcionesArr.length > 1) {
                    // Mantener solo el primer elemento
                    var firstOpt = opcionesArr[0];
                    if (pendingToggleQuestion.tipo === "VerdaderoFalso") {
                        firstOpt.label = "a";
                    } else if (pendingToggleQuestion.tipo === "OpcionMultiple") {
                        firstOpt.label = "A";
                    }
                    pendingToggleQuestion.opcionesJson = JSON.stringify([firstOpt]);
                    
                    // Ajustar respuesta correcta si es necesario
                    if (pendingToggleQuestion.tipo === "OpcionMultiple") {
                        pendingToggleQuestion.respuestaCorrecta = "A";
                    }
                }
                
                pendingToggleQuestion = null;
                document.getElementById("confirm-modal").style.display = "none";
                renderOverlayControls();
                renderQuestionsForm();
            }
        }

        // Añadir una pregunta de forma manual en el visor
        function addManualControl() {
            var qNum = preguntas.length > 0 ? Math.max(...preguntas.map(p => p.numeroPregunta)) + 1 : 1;
            
            // Posicionar en un lugar predeterminado en el centro de la página actual
            var p = {
                numeroPregunta: qNum,
                enunciado: "Pregunta manual " + qNum + ".",
                tipo: "OpcionMultiple",
                respuestaCorrecta: "A",
                puntaje: 2.0,
                posX: 15,
                posY: 30,
                width: 70,
                height: 5,
                opcionesJson: JSON.stringify([
                    { label: "A", x: 17, y: 37, w: 2.5, h: 2.5 },
                    { label: "B", x: 22, y: 37, w: 2.5, h: 2.5 },
                    { label: "C", x: 27, y: 37, w: 2.5, h: 2.5 },
                    { label: "D", x: 32, y: 37, w: 2.5, h: 2.5 },
                    { label: "E", x: 37, y: 37, w: 2.5, h: 2.5 }
                ]),
                tieneSubpreguntas: false,
                page: currentPageNum
            };

            preguntas.push(p);
            preguntas.sort((a, b) => a.numeroPregunta - b.numeroPregunta);
            
            recalcularPuntajeTotal();
            renderOverlayControls();
            renderQuestionsForm();
            selectQuestion(preguntas.indexOf(p));
        }

        // Eliminar pregunta seleccionada
        function deleteSelectedQuestion() {
            if (activeQuestionIndex >= 0 && activeQuestionIndex < preguntas.length) {
                preguntas.splice(activeQuestionIndex, 1);
                activeQuestionIndex = -1;
                document.getElementById("delete-q-btn").disabled = true;
                
                recalcularPuntajeTotal();
                renderOverlayControls();
                renderQuestionsForm();
            }
        }

        // Función Helper para Modales de Alerta
        function showGlassAlert(title, message, isError = true) {
            document.getElementById("alert-title").innerText = title;
            document.getElementById("alert-message").innerText = message;
            
            var icon = document.getElementById("alert-icon");
            if (isError) {
                icon.className = "fa-solid fa-triangle-exclamation";
                icon.style.color = "#ff5252";
            } else {
                icon.className = "fa-solid fa-circle-check";
                icon.style.color = "var(--primary-glow)";
            }

            document.getElementById("glass-alert-modal").style.display = "flex";
        }

        function closeAlertModal() {
            document.getElementById("glass-alert-modal").style.display = "none";
        }

        // 8. Guardar todo el examen en el backend vía AJAX
        function saveExamen() {
            // Validación antes de guardar
            if (preguntas.length === 0) {
                showGlassAlert("Plantilla Vacía", "Debes tener al menos una pregunta en el examen para poder guardarlo.");
                return;
            }

            for (let i = 0; i < preguntas.length; i++) {
                let p = preguntas[i];
                if (!p.puntaje || p.puntaje <= 0) {
                    showGlassAlert("Falta Puntaje", "La Pregunta " + p.numeroPregunta + " debe tener un puntaje mayor a 0.");
                    return;
                }
                if (!p.respuestaCorrecta || p.respuestaCorrecta.trim() === "") {
                    showGlassAlert("Falta Respuesta", "No has definido la respuesta correcta para la Pregunta " + p.numeroPregunta + ".");
                    return;
                }
            }

            var loader = document.getElementById("ocr-loader");
            var loaderTitle = document.getElementById("ocr-loader-title");
            var loaderSubtitle = document.getElementById("ocr-loader-subtitle");
            var fill = document.getElementById("ocr-progress-bar");

            loaderTitle.innerText = "Guardando plantilla...";
            loaderSubtitle.innerText = "Sincronizando coordenadas y solucionario...";
            fill.style.width = "40%";
            loader.style.display = "flex";

            var data = {
                examenId: examenId,
                preguntasJson: JSON.stringify(preguntas),
                stampX: stampX,
                stampY: stampY,
                stampWidth: stampWidth,
                stampHeight: stampHeight
            };

            fetch('@Url.Action("GuardarPlantilla", "Examen")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: Object.keys(data).map(key => encodeURIComponent(key) + '=' + encodeURIComponent(data[key])).join('&')
            })
            .then(response => response.json())
            .then(res => {
                if (res.success) {
                    fill.style.width = "100%";
                    location.href = res.redirectUrl;
                } else {
                    loader.style.display = "none";
                    showGlassAlert("Error al Guardar", res.message || "Hubo un problema sincronizando con el servidor.");
                }
            })
            .catch(err => {
                loader.style.display = "none";
                showGlassAlert("Error de Conexión", "No se pudo conectar con el servidor para guardar la plantilla.");
            });
        }
    </script>
}
