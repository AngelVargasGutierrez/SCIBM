@model SCIBM.Models.Unidad
@{
    ViewBag.Title = $"{Model.Seccion.Curso.Nombre} - {Model.NombreUnidad}";
    ViewBag.Subtitle = $"Gestione las versiones de exámenes y califique";
}

<style>
    /* GRID VERSIONES */
    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        margin-top: 20px;
    }

    .course-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 24px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 16px;
        position: relative;
        overflow: hidden;
    }
    .course-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, var(--accent-color), var(--primary-glow));
        opacity: 0.8;
    }
    .course-card:hover {
        transform: translateY(-5px);
        border-color: rgba(100, 223, 223, 0.3);
        box-shadow: 0 12px 40px 0 rgba(0, 180, 216, 0.15);
    }

    .course-info h3 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #ffffff;
    }

    .course-stats {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 12px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .stat-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .stat-val {
        font-size: 18px;
        font-weight: 700;
        color: var(--primary-glow);
    }
    .stat-lbl {
        font-size: 11px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* ACTION BAR */
    .action-bar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin-bottom: 20px;
    }
    
    /* NO DATA EMPTY STATE */
    .empty-state {
        text-align: center;
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
    }
    .empty-icon {
        font-size: 64px;
        color: var(--text-muted);
        opacity: 0.4;
        animation: float 3s ease-in-out infinite;
    }
    
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .alert {
        padding: 12px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .alert-success {
        background: rgba(46, 196, 182, 0.15);
        color: #2ec4b6;
        border: 1px solid rgba(46, 196, 182, 0.25);
    }
    .alert-danger {
        background: rgba(255, 82, 82, 0.15);
        color: #ff5252;
        border: 1px solid rgba(255, 82, 82, 0.25);
    }

    .edit-btn {
        color: white;
        background: none;
        border: none;
        font-size: 16px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.2s ease;
        padding: 4px;
        margin-left: 8px;
    }
    .edit-btn:hover {
        color: var(--accent-color);
        opacity: 1;
        transform: scale(1.1);
    }
    
    /* CUSTOM FILE INPUT */
    .file-upload-custom {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 25px;
        border: 2px dashed rgba(100, 223, 223, 0.3);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.02);
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        color: var(--text-muted);
        text-align: center;
        gap: 10px;
    }
    .file-upload-custom:hover {
        background: rgba(100, 223, 223, 0.08);
        border-color: var(--primary-glow);
        color: white;
    }
    .file-upload-custom i {
        font-size: 32px;
        color: var(--primary-glow);
    }
</style>



<!-- ALERTAS -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<!-- ACTION BAR -->
<div class="action-bar" style="justify-content: space-between;">
    <a href="@Url.Action("Detail", "Seccion", new { id = Model.SeccionId })" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left"></i> Volver
    </a>
    <button class="btn btn-primary" onclick="openModal()">
        <i class="fa-solid fa-plus"></i> Nueva Versión
    </button>
</div>

<!-- VERSIONES LISTING -->
@if (Model.Examenes == null || !Model.Examenes.Any())
{
    <div class="glass-card empty-state">
        <i class="fa-solid fa-file-invoice empty-icon"></i>
        <h2>No hay versiones de examen</h2>
        <p style="color: var(--text-muted); max-width: 400px; font-size: 15px;">
            Aún no has creado versiones (Ej. Fila A, Fila B). Crea tu primera versión para empezar a calificar.
        </p>
        <button class="btn btn-primary" onclick="openModal()">
            Crear Versión de Examen
        </button>
    </div>
}
else
{
    <div class="courses-grid">
        @foreach (var v in Model.Examenes.OrderBy(e => e.NombreVersion))
        {
            <div class="course-card">
                <div class="course-info" style="display: flex; align-items: center; justify-content: space-between;">
                    <h3 title="@v.NombreVersion" style="margin-bottom: 0;">@v.NombreVersion</h3>
                    <button class="edit-btn" onclick="openEditModal('@v.Id', '@v.NombreVersion')" title="Renombrar">
                        <i class="fa-solid fa-pencil"></i>
                    </button>
                </div>
                
                <div class="course-stats">
                    <div class="stat-item">
                        <span class="stat-val">@v.Preguntas.Count</span>
                        <span class="stat-lbl">Preguntas</span>
                    </div>
                    @if (v.DriveFolderId != null)
                    {
                        <div class="stat-item" style="margin-left: auto;">
                            <span class="stat-val" style="color: var(--primary-glow);"><i class="fa-brands fa-google-drive"></i></span>
                            <span class="stat-lbl">Sincronizado</span>
                        </div>
                    }
                </div>

                <a href="@Url.Action("Detail", "Examen", new { id = v.Id })" class="btn btn-secondary" style="width: 100%;">
                    Gestionar Versión <i class="fa-solid fa-arrow-right" style="margin-left: 6px; font-size: 12px;"></i>
                </a>
            </div>
        }
    </div>
}

<!-- MODAL ADD VERSION -->
<div class="modal-overlay" id="add-version-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Nueva Versión de Examen</h3>
            <button type="button" class="modal-close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="create-version-form" onsubmit="submitForm(event)" action="@Url.Action("CreateVersion", "Examen")" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="unidadId" value="@Model.Id" />
            
            <div class="form-group">
                <label for="nombreVersion">Nombre de la Versión</label>
                <input type="text" id="nombreVersion" name="nombreVersion" class="form-input" placeholder="Ej: Fila A" required />
            </div>

            <div class="form-group">
                <label style="display:block; margin-bottom: 8px;">Seleccionar Archivo PDF (Plantilla del examen)</label>
                <label for="pdfFile" class="file-upload-custom">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                    <span id="file-name-display" style="font-weight: 500;">Haz clic para buscar un archivo .pdf</span>
                </label>
                <input type="file" id="pdfFile" name="pdfFile" accept=".pdf" style="display: none;" required onchange="updateFileName(this)" />
            </div>

            <div id="modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="submit-btn" disabled>
                    <span>Crear Versión</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDIT VERSION -->
<div class="modal-overlay" id="edit-version-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Renombrar Versión</h3>
            <button class="modal-close" onclick="closeEditModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="edit-version-form" onsubmit="submitEditForm(event)">
            <input type="hidden" id="edit-id" />
            <div class="form-group">
                <label for="edit-nombre">Nuevo Nombre</label>
                <input type="text" id="edit-nombre" class="form-input" required />
            </div>

            <div id="edit-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="edit-submit-btn">
                    <span>Guardar Cambios</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- LOADING OVERLAYS -->
<div class="modal-overlay" id="loading-overlay">
    <div class="modal-box" style="text-align: center; width: 300px; padding: 40px 20px;">
        <i class="fa-solid fa-spinner fa-spin" style="font-size: 48px; color: var(--accent-color); margin-bottom: 20px;"></i>
        <h3 id="loading-text">Procesando...</h3>
        <p style="font-size: 12px; color: var(--text-muted); margin-top: 10px;">Por favor no cierres ni recargues la página.</p>
    </div>
</div>

@section scripts {
    <script>
        function openModal() {
            document.getElementById("add-version-modal").classList.add("active");
            document.getElementById("nombreVersion").focus();
        }

        function closeModal() {
            document.getElementById("add-version-modal").classList.remove("active");
            document.getElementById("create-version-form").reset();
            document.getElementById("modal-error").style.display = "none";
            document.getElementById("file-name-display").innerText = "Haz clic para buscar un archivo .pdf";
            document.getElementById("file-name-display").style.color = "";
            document.getElementById("submit-btn").disabled = true;
        }

        function updateFileName(input) {
            var display = document.getElementById("file-name-display");
            var submitBtn = document.getElementById("submit-btn");
            if (input.files && input.files.length > 0) {
                display.innerText = input.files[0].name;
                display.style.color = "var(--primary-glow)";
                submitBtn.disabled = false;
            } else {
                display.innerText = "Haz clic para buscar un archivo .pdf";
                display.style.color = "";
                submitBtn.disabled = true;
            }
        }

        function openEditModal(id, nombre) {
            document.getElementById("edit-id").value = id;
            document.getElementById("edit-nombre").value = nombre;
            document.getElementById("edit-version-modal").classList.add("active");
            document.getElementById("edit-nombre").focus();
        }

        function closeEditModal() {
            document.getElementById("edit-version-modal").classList.remove("active");
            document.getElementById("edit-version-form").reset();
            document.getElementById("edit-modal-error").style.display = "none";
        }

        function submitEditForm(e) {
            e.preventDefault();
            
            var submitBtn = document.getElementById("edit-submit-btn");
            var originalHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Guardando...';

            var id = document.getElementById("edit-id").value;
            var newName = document.getElementById("edit-nombre").value;

            fetch('@Url.Action("Rename", "Examen")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + encodeURIComponent(id) + '&newName=' + encodeURIComponent(newName)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("edit-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al renombrar.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("edit-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

        function submitForm(e) {
            var submitBtn = document.getElementById("submit-btn");
            document.getElementById("loading-text").innerText = "Creando versión y subiendo archivos...";
            document.getElementById("loading-overlay").classList.add("active");
            submitBtn.disabled = true;
        }
    </script>
}
