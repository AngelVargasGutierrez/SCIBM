@model SCIBM.Models.Seccion
@{
    ViewBag.Title = $"{Model.Curso.Nombre} - {Model.Nombre}";
    ViewBag.Subtitle = $"Código del Curso: {Model.Curso.Codigo.ToUpper()} | Sección: {Model.Nombre}";
    var examenes = ViewBag.Examenes as IEnumerable<SCIBM.Models.Examen>;
}

<style>
    /* TWO COLUMN LAYOUT */
    .detail-layout {
        display: grid;
        grid-template-columns: 380px 1fr;
        gap: 30px;
        align-items: start;
    }

    /* STUDENT PANEL */
    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--glass-border);
    }
    .panel-header h2 {
        font-size: 18px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .panel-header h2 span {
        font-size: 12px;
        background: rgba(100, 223, 223, 0.15);
        color: var(--primary-glow);
        padding: 2px 8px;
        border-radius: 20px;
    }

    .student-list {
        max-height: 480px;
        overflow-y: auto;
        overflow-x: auto;
        padding-right: 5px;
    }
    .student-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        transition: background 0.2s;
        min-width: max-content;
    }
    .student-item:hover {
        background: rgba(128, 128, 128, 0.08);
    }
    .student-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(100, 223, 223, 0.1);
        color: var(--primary-glow);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 13px;
        border: 1px solid rgba(100, 223, 223, 0.2);
    }
    .student-name {
        font-size: 14px;
        font-weight: 500;
        white-space: nowrap;
    }

    /* UNITS PANEL */
    .units-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
    }

    .unit-card {
        background: rgba(128, 128, 128, 0.05);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 16px;
        transition: border-color 0.2s;
    }
    .unit-card:hover {
        border-color: rgba(100, 223, 223, 0.25);
        background: rgba(128, 128, 128, 0.08);
    }
    .unit-info {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
    .unit-badge {
        font-size: 12px;
        font-weight: 700;
        background: var(--accent-color);
        color: #0b132b;
        padding: 4px 10px;
        border-radius: 6px;
        text-transform: uppercase;
    }
    
    .exam-status {
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 8px;
    }
    .status-ok {
        color: #2ec4b6;
    }
    .status-warn {
        color: #ffb703;
    }

    /* MESSAGES ALERTS */
    .alert {
        padding: 12px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .alert-success {
        background: rgba(46, 196, 182, 0.15);
        color: #2ec4b6;
        border: 1px solid rgba(46, 196, 182, 0.25);
    }
    .alert-danger {
        background: rgba(255, 82, 82, 0.15);
        color: #ff5252;
        border: 1px solid rgba(255, 82, 82, 0.25);
    }

    /* CUSTOM FILE INPUT */
    .file-upload-custom {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 25px;
        border: 2px dashed rgba(100, 223, 223, 0.3);
        border-radius: 12px;
        background: rgba(128, 128, 128, 0.05);
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        color: var(--text-muted);
        text-align: center;
        gap: 10px;
    }
    .file-upload-custom:hover {
        background: rgba(100, 223, 223, 0.08);
        border-color: var(--primary-glow);
        color: var(--text-color);
    }
    .file-upload-custom i {
        font-size: 32px;
        color: var(--primary-glow);
    }

    .edit-btn {
        color: var(--text-color);
        background: none;
        border: none;
        font-size: 14px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.2s ease;
        padding: 4px;
        margin-left: 8px;
    }
    .edit-btn:hover {
        color: var(--accent-color);
        opacity: 1;
        transform: scale(1.1);
    }

    .delete-btn {
        color: var(--text-color);
        background: none;
        border: none;
        font-size: 14px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.2s ease;
        padding: 4px;
        margin-left: 8px;
    }
    .delete-btn:hover {
        color: #ff5252;
        opacity: 1;
        transform: scale(1.1);
    }
    
    /* BREADCRUMB */
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 15px;
        font-weight: 500;
        color: var(--text-muted);
    }
    .breadcrumb a {
        color: var(--text-color);
        text-decoration: none;
        transition: color 0.2s;
    }
    .breadcrumb a:hover {
        color: var(--primary-glow);
    }
    .breadcrumb-separator {
        color: rgba(255, 255, 255, 0.2);
        font-size: 11px;
    }
    .breadcrumb-current {
        color: var(--primary-glow);
    }
</style>

<!-- SUCCESS/ERROR MESSAGES -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="action-bar">
    <div class="breadcrumb">
        <a href="@Url.Action("Index", "Ciclo")"><i class="fa-solid fa-calendar-days" style="margin-right: 6px;"></i> Ciclos</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <a href="@Url.Action("Index", "Curso", new { cicloId = Model.Curso.CicloAcademicoId })">@Model.Curso.CicloAcademico.Nombre</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <a href="@Url.Action("Detail", "Curso", new { id = Model.CursoId })">@Model.Curso.Nombre</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <span class="breadcrumb-current">@Model.Nombre</span>
    </div>
</div>

<div class="detail-layout">

    <!-- COLUMN 1: STUDENTS LIST -->
    <div class="glass-card">
        <div class="panel-header">
            <h2>Estudiantes <span>@Model.AlumnosMatriculados.Count</span></h2>
            <button class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px;" onclick="openImportModal()" title="Importar lista desde un archivo Excel .xlsx">
                <i class="fa-solid fa-file-import"></i> Importar
            </button>
        </div>

        @if (!Model.AlumnosMatriculados.Any())
        {
            <div style="text-align: center; padding: 40px 10px; color: var(--text-muted); font-size: 14px;">
                <i class="fa-solid fa-users" style="font-size: 36px; opacity: 0.3; margin-bottom: 12px; display: block;"></i>
                <div style="margin-bottom: 10px;">No hay alumnos matriculados en este curso.</div>
                <div style="font-size: 12.5px; opacity: 0.7; max-width: 250px; margin: 0 auto; line-height: 1.5;">
                    <strong>Nota:</strong> Solo archivos .xlsx, sin encabezado, con una sola columna en la primera hoja.
                </div>
            </div>
        }
        else
        {
            <div class="student-list">
                @foreach (var al in Model.AlumnosMatriculados.OrderBy(a => a.NombreCompleto))
                {
                    // Obtener iniciales para el avatar redondo
                    string initials = "";
                    if (!string.IsNullOrEmpty(al.Nombres)) { initials += al.Nombres[0]; }
                    if (!string.IsNullOrEmpty(al.Apellidos)) { initials += al.Apellidos[0]; }
                    if (initials.Length == 0 && al.NombreCompleto.Length > 0) { initials += al.NombreCompleto[0]; }

                    <div class="student-item">
                        <div class="student-avatar">@initials.ToUpper()</div>
                        <div class="student-name" title="@al.NombreCompleto">@al.NombreCompleto</div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- COLUMN 2: EXAM UNITS -->
    <div class="glass-card">
        <div class="panel-header">
            <h2>Unidades de Examen</h2>
            <button class="btn btn-primary" onclick="openUnitModal()">
                <i class="fa-solid fa-plus"></i> Nueva Unidad
            </button>
        </div>

        @if (!Model.Unidades.Any())
        {
            <div style="text-align: center; padding: 80px 20px; color: var(--text-muted);">
                <i class="fa-solid fa-folder-open" style="font-size: 48px; opacity: 0.3; margin-bottom: 16px; display: block;"></i>
                <h3>No hay unidades creadas</h3>
                <p style="font-size: 14px; margin-top: 6px;">Crea una unidad (ej: Unidad 1, U1R, Unidad 2) para subir su examen.</p>
            </div>
        }
        else
        {
            <div class="units-grid">
                @foreach (var un in Model.Unidades.OrderBy(u => u.NombreUnidad))
                {
                    var versiones = examenes?.Where(e => e.UnidadId == un.Id).ToList();
                    var tieneVersiones = versiones != null && versiones.Any();
                    
                    <div class="unit-card">
                        <div>
                            <div class="unit-info">
                                <div style="display: flex; align-items: center;">
                                    <span class="unit-badge">@un.NombreUnidad</span>
                                    <button class="edit-btn" onclick="openEditModal('@un.Id', '@un.NombreUnidad')" title="Renombrar">
                                        <i class="fa-solid fa-pencil"></i>
                                    </button>
                                    <button class="delete-btn" onclick="openDeleteModal('@un.Id', '@un.NombreUnidad')" title="Eliminar">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                                @if (un.DriveFolderId != null)
                                {
                                    <span style="font-size: 13px; color: var(--text-muted);" title="Sincronizado con Google Drive"><i class="fa-brands fa-google-drive"></i></span>
                                }
                            </div>
                            
                            <div class="exam-status">
                                @if (tieneVersiones)
                                {
                                    <span class="status-ok"><i class="fa-solid fa-circle-check"></i> @versiones.Count versión(es)</span>
                                }
                                else
                                {
                                    <span class="status-warn"><i class="fa-solid fa-triangle-exclamation"></i> Faltan versiones</span>
                                }
                            </div>
                        </div>

                        <div>
                            @if (tieneVersiones)
                            {
                                <a href="@Url.Action("Detail", "Unidad", new { id = un.Id })" class="btn btn-secondary" style="width: 100%; font-size: 13px; padding: 8px 12px;">
                                    Ver Versiones <i class="fa-solid fa-arrow-right" style="margin-left: 6px; font-size: 11px;"></i>
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("Detail", "Unidad", new { id = un.Id })" class="btn btn-primary" style="width: 100%; font-size: 13px; padding: 8px 12px;">
                                    Configurar Versiones <i class="fa-solid fa-gear" style="margin-left: 6px; font-size: 11px;"></i>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

<!-- MODAL IMPORT EXCEL -->
<div class="modal-overlay" id="import-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Importar Alumnos Matriculados</h3>
            <button class="modal-close" onclick="closeImportModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="import-form" onsubmit="submitImportForm(event)">
            <input type="hidden" id="importSeccionId" name="seccionId" value="@Model.Id" />
            
            <div style="background: rgba(100, 223, 223, 0.05); padding: 15px; border-radius: 8px; border: 1px solid rgba(100, 223, 223, 0.15); margin-bottom: 20px; font-size: 13px; color: var(--text-muted);">
                <i class="fa-solid fa-info-circle" style="color: var(--primary-glow); margin-right: 6px;"></i>
                Sube un archivo Excel (<strong>.xlsx</strong>) de una sola columna sin encabezado. El sistema reconoce nombres en formato <i>"Apellido, Nombre"</i> o <i>"Nombre Apellido"</i>.
            </div>

            <div class="form-group">
                <label style="display:block; margin-bottom: 8px;">Seleccionar Archivo Excel</label>
                <label for="archivoExcel" class="file-upload-custom">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                    <span id="file-name-display" style="font-weight: 500;">Haz clic para buscar un archivo .xlsx</span>
                </label>
                <input type="file" id="archivoExcel" name="archivoExcel" accept=".xlsx" style="display: none;" required onchange="updateFileName(this)" />
            </div>

            <div id="import-modal-error" style="color: #ff5252; font-size: 13px; margin-top: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeImportModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="import-submit-btn">Importar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL ADD UNIT -->
<div class="modal-overlay" id="add-unit-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Nueva Unidad de Examen</h3>
            <button class="modal-close" onclick="closeUnitModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="create-unit-form" onsubmit="submitUnitForm(event)">
            <input type="hidden" id="unitSeccionId" name="seccionId" value="@Model.Id" />
            
            <div class="form-group">
                <label for="nombreUnidad">Nombre de la Unidad (ej: U1, U1R, U2)</label>
                <input type="text" id="nombreUnidad" name="nombreUnidad" class="form-input" placeholder="Ej: U1" required />
            </div>

            <div id="unit-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeUnitModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="unit-submit-btn">
                    <span>Guardar y Crear Carpeta en Drive</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL DELETE UNIT -->
<div class="modal-overlay" id="delete-unit-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Eliminar Unidad</h3>
            <button class="modal-close" onclick="closeDeleteModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <p style="margin-bottom: 20px; font-size: 15px; color: var(--text-muted);">
            ¿Estás seguro que deseas eliminar la unidad <strong id="delete-unit-nombre" style="color: var(--text-color);"></strong>? <br><br>
            <span style="color: #ff5252;"><i class="fa-solid fa-triangle-exclamation"></i> Advertencia:</span> Esto eliminará permanentemente todas las versiones de examen y calificaciones de los alumnos asociadas a esta unidad.
        </p>
        <form id="delete-unit-form" onsubmit="submitDeleteForm(event)">
            <input type="hidden" id="delete-id" />
            <div id="delete-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>
            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 10px;">
                <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="delete-submit-btn" style="background: #ff5252; box-shadow: 0 4px 15px 0 rgba(255, 82, 82, 0.4); border: none;">
                    <span>Sí, Eliminar</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDIT UNIT -->
<div class="modal-overlay" id="edit-unit-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Renombrar Unidad</h3>
            <button class="modal-close" onclick="closeEditModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="edit-unit-form" onsubmit="submitEditForm(event)">
            <input type="hidden" id="edit-id" />
            <div class="form-group">
                <label for="edit-nombre">Nuevo Nombre</label>
                <input type="text" id="edit-nombre" class="form-input" required />
            </div>

            <div id="edit-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="edit-submit-btn">
                    <span>Guardar Cambios</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL CONFLICT -->
<div class="modal-overlay" id="conflict-modal">
    <div class="modal-box" style="max-width: 480px;">
        <div class="modal-header">
            <h3 style="color: #ffb703;"><i class="fa-solid fa-triangle-exclamation"></i> Reemplazo de Lista</h3>
            <button class="modal-close" onclick="closeConflictModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="padding: 10px 0; color: var(--text-muted); font-size: 14px; line-height: 1.5;">
            Se ha detectado que <strong>ya existen alumnos con exámenes calificados</strong> en esta sección. 
            <br><br>
            ¿Qué deseas hacer con la lista actual antes de importar?
            <ul style="margin-top: 10px; padding-left: 20px;">
                <li style="margin-bottom: 8px;"><strong>Continuar:</strong> Limpiará a TODOS los alumnos. Los exámenes calificados perderán a su alumno asociado.</li>
                <li><strong>Conservar:</strong> Solo limpiará a los alumnos sin examen. Conservará a los ya calificados.</li>
            </ul>
        </div>
        <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
            <button type="button" class="btn btn-secondary" onclick="closeConflictModal()">Cancelar</button>
            <button type="button" class="btn btn-primary" onclick="proceedImport('Conservar')" style="background: var(--accent-color); color: #0b132b;">Conservar</button>
            <button type="button" class="btn btn-secondary" onclick="proceedImport('Continuar')" style="border-color: #ff5252; color: #ff5252;">Continuar</button>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // MODAL IMPORT
        function openImportModal() {
            document.getElementById("import-modal").classList.add("active");
        }
        function closeImportModal() {
            document.getElementById("import-modal").classList.remove("active");
            document.getElementById("import-form").reset();
            document.getElementById("import-modal-error").style.display = "none";
            document.getElementById("file-name-display").innerText = "Haz clic para buscar un archivo .xlsx";
            document.getElementById("file-name-display").style.color = "";
        }
        function updateFileName(input) {
            var displaySpan = document.getElementById("file-name-display");
            if (input.files && input.files.length > 0) {
                displaySpan.innerText = input.files[0].name;
                displaySpan.style.color = "#2ec4b6"; // Color accent
            } else {
                displaySpan.innerText = "Haz clic para buscar un archivo .xlsx";
                displaySpan.style.color = "";
            }
        }
        var currentFormData = null;
        var currentSubmitBtn = null;
        var currentOrigHtml = null;

        function submitImportForm(e) {
            e.preventDefault();
            
            currentSubmitBtn = document.getElementById("import-submit-btn");
            currentOrigHtml = currentSubmitBtn.innerHTML;
            
            currentSubmitBtn.disabled = true;
            currentSubmitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verificando...';
            
            var seccionId = document.getElementById("importSeccionId").value;
            currentFormData = new FormData();
            currentFormData.append('seccionId', seccionId);
            currentFormData.append('archivoExcel', document.getElementById("archivoExcel").files[0]);

            fetch('@Url.Action("CheckExamenesCalificados", "Seccion")?seccionId=' + seccionId)
            .then(res => res.json())
            .then(data => {
                if (data.hasGraded) {
                    document.getElementById("import-modal").classList.remove("active");
                    document.getElementById("conflict-modal").classList.add("active");
                    currentSubmitBtn.disabled = false;
                    currentSubmitBtn.innerHTML = currentOrigHtml;
                } else {
                    proceedImport('Conservar');
                }
            })
            .catch(err => {
                proceedImport('Conservar'); // default on error
            });
        }

        function closeConflictModal() {
            document.getElementById("conflict-modal").classList.remove("active");
            document.getElementById("import-form").reset();
            document.getElementById("file-name-display").innerText = "Haz clic para buscar un archivo .xlsx";
        }

        function proceedImport(strategy) {
            document.getElementById("conflict-modal").classList.remove("active");
            currentFormData.set('strategy', strategy);
            
            if (currentSubmitBtn && !document.getElementById("conflict-modal").classList.contains("active")) {
                currentSubmitBtn.disabled = true;
                currentSubmitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Importando...';
            } else {
                document.body.style.cursor = "wait";
            }

            fetch('@Url.Action("ImportarAlumnos", "Seccion")', {
                method: 'POST',
                body: currentFormData
            })
            .then(response => response.text())
            .then(text => {
                try {
                    var data = JSON.parse(text);
                    if (data.success) {
                        location.reload();
                    } else {
                        document.body.style.cursor = "default";
                        if (currentSubmitBtn) { currentSubmitBtn.disabled = false; currentSubmitBtn.innerHTML = currentOrigHtml; }
                        // Mostramos el modal de importación de nuevo con el error
                        document.getElementById("import-modal").classList.add("active");
                        var errDiv = document.getElementById("import-modal-error");
                        errDiv.innerText = data.message || "Ocurrió un error al importar.";
                        errDiv.style.display = "block";
                    }
                } catch(e) {
                    document.write(text);
                }
            })
            .catch(error => {
                document.body.style.cursor = "default";
                if (currentSubmitBtn) { currentSubmitBtn.disabled = false; currentSubmitBtn.innerHTML = currentOrigHtml; }
                document.getElementById("import-modal").classList.add("active");
                var errDiv = document.getElementById("import-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

        // MODAL UNIT
        function openUnitModal() {
            document.getElementById("add-unit-modal").classList.add("active");
            document.getElementById("nombreUnidad").focus();
        }
        function closeUnitModal() {
            document.getElementById("add-unit-modal").classList.remove("active");
            document.getElementById("create-unit-form").reset();
            document.getElementById("unit-modal-error").style.display = "none";
        }
        function submitUnitForm(e) {
            e.preventDefault();
            
            var submitBtn = document.getElementById("unit-submit-btn");
            var originalHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creando en Drive...';

            var seccionId = document.getElementById("unitSeccionId").value;
            var nombreUnidad = document.getElementById("nombreUnidad").value;

            fetch('@Url.Action("Create", "Unidad")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'seccionId=' + encodeURIComponent(seccionId) + '&nombreUnidad=' + encodeURIComponent(nombreUnidad)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("unit-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al crear la unidad.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("unit-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

