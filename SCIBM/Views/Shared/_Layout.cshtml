<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - SCIBM</title>
    <!-- Evitar parpadeo blanco nativo del navegador -->
    <meta name="color-scheme" content="dark light">
    <script>
        // Aplicar tema antes del render para evitar parpadeos
        const savedTheme = localStorage.getItem('scibm-theme') || 'dark';
        if (savedTheme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
        }
    </script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome para iconos -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    
    <style>
        :root {
            --bg-color: #0b132b;
            --sidebar-bg: #1c2541;
            --primary-glow: #64dfdf;
            --accent-color: #48cae4;
            --accent-hover: #00b4d8;
            --text-color: #f1faee;
            --text-muted: #a8dadc;
            --glass-bg: rgba(28, 37, 65, 0.7);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }

        [data-theme="light"] {
            --bg-color: #f0f4f8;
            --sidebar-bg: #ffffff;
            --primary-glow: #1a73e8;
            --accent-color: #1a73e8;
            --accent-hover: #1557b0;
            --text-color: #1f2937;
            --text-muted: #6b7280;
            --glass-bg: rgba(255, 255, 255, 0.85);
            --glass-border: rgba(0, 0, 0, 0.08);
            --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.08);
        }

        html {
            background-color: var(--bg-color); /* Fondo base dinámico */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Outfit', sans-serif;
            scrollbar-width: thin;
            scrollbar-color: var(--accent-color) var(--bg-color);
        }

        *::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        *::-webkit-scrollbar-track {
            background: var(--bg-color);
        }
        *::-webkit-scrollbar-thumb {
            background-color: var(--accent-color);
            border-radius: 10px;
        }

        @@keyframes pageFadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        body {
            background: var(--bg-color);
            color: var(--text-color);
            min-height: 100vh;
            display: flex;
            overflow-x: hidden;
            animation: pageFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        /* SIDEBAR CONTAINER */
        aside {
            width: 280px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--glass-border);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 1000;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* BRAND */
        .brand {
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--glass-border);
        }
        .brand i {
            font-size: 28px;
            color: var(--primary-glow);
            text-shadow: 0 0 10px var(--primary-glow);
        }
        .brand span {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 1px;
            background: linear-gradient(to right, var(--text-color), var(--primary-glow));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            flex-grow: 1;
        }

        /* THEME TOGGLE */
        .theme-switch {
            position: relative;
            display: inline-block;
            width: 56px;
            height: 30px;
            margin-left: auto;
            flex-shrink: 0;
        }
        .theme-switch input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute;
        }
        .theme-switch .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #1c2541;
            transition: background-color .4s;
            border-radius: 30px;
            border: 1px solid var(--primary-glow);
            display: flex;
            align-items: center;
        }
        .theme-switch .slider .ball {
            position: absolute;
            height: 24px;
            width: 24px;
            left: 2px;
            background-color: #64dfdf;
            transition: transform .4s, background-color .4s;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 1px 4px rgba(0,0,0,0.3);
        }
        .theme-switch input:checked + .slider {
            background-color: #dce8f7;
            border-color: #1a73e8;
        }
        .theme-switch input:checked + .slider .ball {
            transform: translateX(26px);
            background-color: #1a73e8;
        }
        .theme-switch .slider .ball i {
            font-size: 13px;
            color: #0b132b;
            transition: color .4s;
        }
        .theme-switch input:checked + .slider .ball i {
            color: #ffffff;
        }

        /* NAVIGATION MENU */
        .menu {
            flex-grow: 1;
            padding: 20px 14px;
            overflow-y: auto;
        }
        .menu-title {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin-bottom: 12px;
            padding-left: 10px;
            opacity: 0.7;
        }
        .menu-item {
            list-style: none;
            margin-bottom: 6px;
        }
        .menu-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 14px;
            color: var(--text-color);
            text-decoration: none;
            border-radius: 8px;
            font-size: 18px;
            font-weight: 500;
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .menu-link div {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .menu-link i.icon-left {
            width: 20px;
            text-align: center;
            font-size: 16px;
        }
        .menu-link:hover, .menu-link.active {
            background: rgba(128, 128, 128, 0.15);
            color: var(--primary-glow);
        }
        .menu-link.active i.icon-left {
            color: var(--primary-glow);
        }

        /* ACCORDION REPORTES */
        .submenu {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            padding-left: 36px;
            margin-top: 4px;
        }
        .submenu-item {
            list-style: none;
            margin-bottom: 4px;
        }
        .submenu-link {
            display: block;
            padding: 8px 12px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 15px;
            border-radius: 6px;
            transition: all 0.2s ease;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .submenu-link:hover, .submenu-link.active {
            color: var(--primary-glow);
            padding-left: 16px;
            background: rgba(128, 128, 128, 0.08);
        }

        .menu-item.open .submenu {
            max-height: 300px; /* Suficiente espacio para listar cursos */
        }
        .menu-item.open .chevron {
            transform: rotate(90deg);
        }
        .chevron {
            transition: transform 0.2s ease;
            font-size: 12px;
        }

        /* USER PROFILE (TOP) */
        .user-profile {
            padding: 20px;
            background: rgba(26, 115, 232, 0.08); /* Azulito pastel adaptable */
            border-bottom: 1px solid var(--glass-border);
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .user-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 2px solid var(--primary-glow);
            object-fit: cover;
            box-shadow: 0 0 10px rgba(100, 223, 223, 0.2);
        }
        .user-info {
            flex-grow: 1;
            overflow: hidden;
        }
        .user-name {
            font-size: 16px;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .user-role {
            font-size: 13px;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* SIDEBAR BOTTOM (LOGOUT) */
        .sidebar-bottom {
            padding: 20px;
            border-top: 1px solid var(--glass-border);
            display: flex;
            justify-content: center;
        }
        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-muted);
            font-size: 18px;
            font-weight: 500;
            transition: color 0.2s ease, background 0.2s ease;
            text-decoration: none;
            width: 100%;
            padding: 8px 12px;
            border-radius: 8px;
        }
        .logout-btn i {
            font-size: 20px;
        }
        .logout-btn:hover {
            color: #ff6b6b;
            background: rgba(255, 107, 107, 0.1);
        }

        /* MAIN WRAPPER */
        main {
            margin-left: 280px;
            flex-grow: 1;
            padding: 40px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            gap: 30px;
            transition: margin-left 0.3s ease;
        }

        /* TOP HEADER */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            padding: 16px 28px;
            border-radius: 16px;
            backdrop-filter: blur(12px);
            box-shadow: var(--glass-shadow);
        }
        .header-title h1 {
            font-size: 19px;
            font-weight: 700;
            color: var(--text-color); /* Blanco en oscuro */
            transition: color 0.3s ease;
        }
        [data-theme="light"] .header-title h1 {
            color: #1a73e8; /* Azul en claro */
        }
        .header-title span {
            font-size: 13px;
            color: var(--text-muted);
        }
        
        .header-folder {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(100, 223, 223, 0.1);
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid rgba(100, 223, 223, 0.2);
            font-size: 14px;
            font-weight: 500;
            color: var(--primary-glow);
        }
        .header-folder i {
            font-size: 16px;
        }

        /* BREADCRUMB GLOBAL STYLES */
        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .breadcrumb a, .breadcrumb span:not(.breadcrumb-separator) {
            display: inline-flex !important;
            align-items: center !important;
            gap: 6px !important;
            padding: 8px 14px !important;
            border-radius: 8px !important;
            background: rgba(128,128,128,0.1) !important;
            color: var(--text-color) !important;
            font-size: 14px !important;
            font-weight: 500 !important;
            text-decoration: none !important;
            transition: all 0.2s !important;
        }
        .breadcrumb a:hover {
            background: rgba(128,128,128,0.2) !important;
        }
        .breadcrumb span.breadcrumb-current {
            background: rgba(100, 223, 223, 0.15) !important;
            color: var(--primary-glow) !important; /* Celeste/Cian en oscuro */
            font-weight: 600 !important;
        }
        [data-theme="light"] .breadcrumb span.breadcrumb-current {
            background: rgba(26, 115, 232, 0.15) !important;
            color: #1a73e8 !important; /* Azul en claro */
        }
        .breadcrumb i.breadcrumb-separator {
            color: var(--text-color) !important;
            font-size: 12px !important;
            opacity: 0.6 !important;
            padding: 0 !important;
            background: transparent !important;
        }

        /* GLASS CARD COMMON STYLE */
        .glass-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 28px;
            backdrop-filter: blur(12px);
            box-shadow: var(--glass-shadow);
        }

        /* MODALES MODERNOS */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(5, 8, 22, 0.85);
            backdrop-filter: blur(8px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }
        .modal-box {
            background: var(--sidebar-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            width: 480px;
            max-width: 90%;
            padding: 30px;
            box-shadow: var(--glass-shadow);
            transform: scale(0.9);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .modal-overlay.active .modal-box {
            transform: scale(1);
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .modal-header h3 {
            font-size: 20px;
            font-weight: 600;
        }
        .modal-close {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 18px;
            cursor: pointer;
            transition: color 0.2s;
        }
        .modal-close:hover {
            color: var(--text-color);
        }

        /* BOTONES PREMIUM */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            text-decoration: none;
        }
        .btn-primary {
            background: var(--accent-color);
            color: #ffffff;
        }
        .btn-primary:hover {
            background: var(--accent-hover);
            box-shadow: 0 0 15px rgba(0, 180, 216, 0.4);
            transform: translateY(-1px);
        }
        .btn:disabled {
            cursor: not-allowed;
            pointer-events: none;
            opacity: 0.6;
        }
        .btn-primary:disabled {
            background: var(--glass-border);
            color: var(--text-muted);
            border: 1px dashed var(--text-muted);
            box-shadow: none;
            transform: none;
        }
        .btn-secondary {
            background: rgba(255, 255, 255, 0.08);
            color: var(--text-color);
            border: 1px solid var(--glass-border);
        }
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.12);
        }
        .btn-danger {
            background: #ff5252;
            color: #ffffff;
        }
        .btn-danger:hover {
            background: #ff7676;
            box-shadow: 0 0 15px rgba(255, 82, 82, 0.4);
        }
        .btn-success {
            background: #2ec4b6;
            color: #0b132b;
        }
        .btn-success:hover {
            background: #4de1d4;
            box-shadow: 0 0 15px rgba(46, 196, 182, 0.4);
        }

        /* FORM INPUTS */
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-muted);
            margin-bottom: 8px;
        }
        .form-input {
            width: 100%;
            padding: 12px 14px;
            background: rgba(128, 128, 128, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: 8px;
            color: var(--text-color);
            font-size: 15px;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-input:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 10px rgba(72, 202, 228, 0.25);
        }
        .form-input option {
            background-color: var(--sidebar-bg);
            color: var(--text-color);
        }

        /* ALERTAS ANIMACION */
        .alert {
            transition: opacity 0.5s ease, height 0.5s ease, padding 0.5s ease, margin 0.5s ease, border-width 0.5s ease;
            overflow: hidden;
        }
        .alert.fade-out {
            opacity: 0 !important;
            height: 0 !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
            margin-top: 0 !important;
            margin-bottom: 0 !important;
            border-width: 0 !important;
        }
    </style>
    @RenderSection("styles", required: false)
</head>
<body>

    <!-- SIDEBAR NAV -->
    <aside>
        <div>
            <!-- LOGO/BRAND -->
            <div class="brand">
                <img id="brand-logo" src="~/Content/images/logo_upt.png" alt="Logo UPT" style="width: 50px; height: 60px; object-fit: contain; margin: -10px 15px -10px -5px;" />
                <span>SCIBM</span>
                <label class="theme-switch" title="Cambiar tema">
                    <input type="checkbox" id="theme-checkbox" onchange="toggleTheme()">
                    <span class="slider">
                        <span class="ball">
                            <i class="fa-solid fa-moon" id="theme-ball-icon"></i>
                        </span>
                    </span>
                </label>
            </div>

            <!-- USER INFO PROFILE -->
            <div class="user-profile">
                <img src="@(Session["UserPicture"] ?? "https://ui-avatars.com/api/?name=Docente&background=1c2541&color=64dfdf")" alt="Docente Avatar" class="user-avatar" referrerpolicy="no-referrer" />
                <div class="user-info">
                    <div class="user-name">@(Session["UserName"] ?? "Docente UPT")</div>
                    <div class="user-role" title="@(Session["UserEmail"])">@(Session["UserEmail"] ?? "Invitado")</div>
                </div>
            </div>

            <!-- MENU -->
            <ul class="menu">
                <li class="menu-title">Docente</li>
                <li class="menu-item">
                    <a href="@Url.Action("Index", "Ciclo")" class="menu-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ciclo" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <div>
                            <i class="fa-solid fa-calendar-days icon-left"></i>
                            <span>Ciclos Académicos</span>
                        </div>
                    </a>
                </li>
                
                <li class="menu-title">Métricas y Reportes</li>
                @{
                    bool isReportActive = ViewContext.RouteData.Values["controller"]?.ToString() == "Reporte";
                }
                <li class="menu-item">
                    <a href="@Url.Action("Index", "Reporte")" class="menu-link @(isReportActive ? "active" : "")">
                        <div>
                            <i class="fa-solid fa-chart-line icon-left"></i>
                            <span>Reportes</span>
                        </div>
                    </a>
                </li>
            </ul>
        </div>

        <!-- LOGOUT FOOTER -->
        <div class="sidebar-bottom">
            <a href="@Url.Action("Logout", "Auth")" class="logout-btn" title="Cerrar Sesión">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Cerrar Sesión</span>
            </a>
        </div>
    </aside>

    <!-- CONTENT WRAPPER -->
    <main>
        <!-- TOP HEADER -->
        <header>
            <div class="header-title">
                <h1>@ViewBag.Title</h1>
                <span>@ViewBag.Subtitle</span>
            </div>
            
            @if (Session["DriveFolderId"] != null)
            {
                // Extraer el nombre de la carpeta formateada (SCIBM_Elanchipa)
                string rootFolderId = Session["DriveFolderId"].ToString();
                string fLetter = !string.IsNullOrEmpty(Session["UserFirstName"]?.ToString()) ? Session["UserFirstName"].ToString().Substring(0, 1).ToUpper() : "U";
                string lName = "Docente";
                if (!string.IsNullOrEmpty(Session["UserLastName"]?.ToString()))
                {
                    var parts = Session["UserLastName"].ToString().Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length > 0)
                    {
                        lName = parts[0];
                        lName = char.ToUpper(lName[0]) + lName.Substring(1).ToLower();
                    }
                }
                string rootFolderName = $"SCIBM_{fLetter}{lName}";

                <div class="header-folder" title="ID de Carpeta Raíz: @rootFolderId">
                    <i class="fa-brands fa-google-drive"></i>
                    <span>@rootFolderName</span>
                </div>
            }
        </header>

        <!-- CONTAINER FOR VIEWS -->
        @RenderBody()
    </main>

    <script>
        // Lógica para alternar el tema claro/oscuro
        function toggleTheme() {
            const html = document.documentElement;
            const logo = document.getElementById('brand-logo');
            const ballIcon = document.getElementById('theme-ball-icon');
            
            if (html.getAttribute('data-theme') === 'light') {
                html.removeAttribute('data-theme');
                localStorage.setItem('scibm-theme', 'dark');
                if (logo) logo.src = '/Content/images/logo_upt.png';
                if (ballIcon) { ballIcon.classList.remove('fa-sun'); ballIcon.classList.add('fa-moon'); }
            } else {
                html.setAttribute('data-theme', 'light');
                localStorage.setItem('scibm-theme', 'light');
                if (logo) logo.src = '/Content/images/logo_claro.png';
                if (ballIcon) { ballIcon.classList.remove('fa-moon'); ballIcon.classList.add('fa-sun'); }
            }
            // Emitir evento para que los gráficos (Chart.js) y otros componentes se re-dibujen
            document.dispatchEvent(new Event('themeChanged'));
        }
        
        // Ajustar logo, checkbox e icono al cargar según el tema
        document.addEventListener('DOMContentLoaded', () => {
            const checkbox = document.getElementById('theme-checkbox');
            const logo = document.getElementById('brand-logo');
            const ballIcon = document.getElementById('theme-ball-icon');
            
            if (document.documentElement.getAttribute('data-theme') === 'light') {
                if (checkbox) checkbox.checked = true;
                if (logo) logo.src = '/Content/images/logo_claro.png';
                if (ballIcon) { ballIcon.classList.remove('fa-moon'); ballIcon.classList.add('fa-sun'); }
            } else {
                if (logo) logo.src = '/Content/images/logo_upt.png';
            }
        });

        function toggleAccordion() {
            var accordion = document.getElementById("reportes-accordion");
            if(accordion) {
                accordion.classList.toggle("open");
            }
        }

        // Auto-dismiss alerts smoothly after 4 seconds
        document.addEventListener("DOMContentLoaded", function () {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                setTimeout(function() {
                    alert.style.height = alert.offsetHeight + 'px';
                    // Force reflow
                    alert.offsetHeight; 
                    alert.classList.add('fade-out');
                    setTimeout(() => alert.remove(), 500);
                }, 4000);
            });
        });
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
