@model SCIBM.Models.Unidad
@using Newtonsoft.Json
@{
    ViewBag.Title = $"{Model.Seccion.Curso.Nombre} - {Model.NombreUnidad}";
    ViewBag.Subtitle = $"Gestione las versiones de exámenes y califique";
}

<style>
    /* GRID VERSIONES */
    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        margin-top: 20px;
    }

    .course-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 24px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 16px;
        position: relative;
        overflow: hidden;
    }
    .course-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, var(--accent-color), var(--primary-glow));
        opacity: 0.8;
    }
    .course-card:hover {
        transform: translateY(-5px);
        border-color: rgba(100, 223, 223, 0.3);
        box-shadow: 0 12px 40px 0 rgba(0, 180, 216, 0.15);
    }

    .course-info h3 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--text-color);
    }

    .course-stats {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 12px 0;
        border-top: 1px solid var(--glass-border);
        border-bottom: 1px solid var(--glass-border);
    }
    .stat-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .stat-val {
        font-size: 18px;
        font-weight: 700;
        color: var(--primary-glow);
    }
    .stat-lbl {
        font-size: 11px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* ACTION BAR & BREADCRUMB */
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .breadcrumb {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        font-size: 15px;
        font-weight: 500;
        color: var(--text-muted);
    }
    .breadcrumb a {
        color: var(--text-color);
        text-decoration: none;
        transition: color 0.2s;
    }
    .breadcrumb a:hover {
        color: var(--primary-glow);
    }
    .breadcrumb-separator {
        color: var(--text-muted);
        font-size: 11px;
    }
    .breadcrumb-current {
        color: var(--primary-glow);
    }
    
    /* NO DATA EMPTY STATE */
    .empty-state {
        text-align: center;
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
    }
    .empty-icon {
        font-size: 64px;
        color: var(--text-muted);
        opacity: 0.4;
        animation: float 3s ease-in-out infinite;
    }
    
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .alert {
        padding: 12px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .alert-success {
        background: rgba(46, 196, 182, 0.15);
        color: #2ec4b6;
        border: 1px solid rgba(46, 196, 182, 0.25);
    }
    .alert-danger {
        background: rgba(255, 82, 82, 0.15);
        color: #ff5252;
        border: 1px solid rgba(255, 82, 82, 0.25);
    }

    .edit-btn {
        color: var(--text-color);
        background: none;
        border: none;
        font-size: 16px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.2s ease;
        padding: 4px;
    }
    .edit-btn:hover {
        color: var(--accent-color);
        opacity: 1;
        transform: scale(1.1);
    }

    .delete-btn {
        color: var(--text-color);
        background: none;
        border: none;
        font-size: 16px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.2s ease;
        padding: 4px;
    }
    .delete-btn:hover {
        color: #ff5252;
        opacity: 1;
        transform: scale(1.1);
    }
    
    /* CUSTOM FILE INPUT */
    .file-upload-custom {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 25px;
        border: 2px dashed rgba(100, 223, 223, 0.3);
        border-radius: 12px;
        background: rgba(128, 128, 128, 0.05);
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        color: var(--text-muted);
        text-align: center;
        gap: 10px;
    }
    .file-upload-custom:hover {
        background: rgba(100, 223, 223, 0.08);
        border-color: var(--primary-glow);
        color: var(--text-color);
    }
    .file-upload-custom i {
        font-size: 32px;
        color: var(--primary-glow);
    }
</style>



<!-- ALERTAS -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<!-- ACTION BAR -->
<div class="action-bar">
    <div class="breadcrumb">
        <a href="@Url.Action("Index", "Ciclo")"><i class="fa-solid fa-calendar-days" style="margin-right: 6px;"></i> Ciclos</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <a href="@Url.Action("Index", "Curso", new { cicloId = Model.Seccion.Curso.CicloAcademicoId })">@Model.Seccion.Curso.CicloAcademico.Nombre</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <a href="@Url.Action("Detail", "Curso", new { id = Model.Seccion.CursoId })">@Model.Seccion.Curso.Nombre</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <a href="@Url.Action("Detail", "Seccion", new { id = Model.SeccionId })">@Model.Seccion.Nombre</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <span class="breadcrumb-current">@Model.NombreUnidad</span>
    </div>
    <button class="btn btn-primary" onclick="openModal()">
        <i class="fa-solid fa-plus"></i> Nueva Versión
    </button>
</div>

<!-- VERSIONES LISTING -->
@if (Model.Examenes == null || !Model.Examenes.Any())
{
    <div class="glass-card empty-state">
        <i class="fa-solid fa-file-invoice empty-icon"></i>
        <h2>No hay versiones de examen</h2>
        <p style="color: var(--text-muted); max-width: 400px; font-size: 15px;">
            Aún no has creado versiones (Ej. Fila A, Fila B). Crea tu primera versión para empezar a calificar.
        </p>
        <button class="btn btn-primary" onclick="openModal()">
            Crear Versión de Examen
        </button>
    </div>
}
else
{
    <div class="courses-grid">
        @foreach (var v in Model.Examenes.OrderBy(e => e.NombreVersion))
        {
            <div class="course-card">
                <div class="course-info" style="display: flex; align-items: flex-start; justify-content: space-between;">
                    <h3 title="@v.NombreVersion" style="margin-bottom: 0;">@v.NombreVersion</h3>
                    <div style="display: flex; gap: 8px;">
                        <button class="edit-btn" onclick="openEditModal('@v.Id', '@v.NombreVersion')" title="Renombrar">
                            <i class="fa-solid fa-pencil"></i>
                        </button>
                        <button class="delete-btn" onclick="openDeleteModal('@v.Id', '@v.NombreVersion')" title="Eliminar">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </div>
                </div>
                
                <div class="course-stats">
                    <div class="stat-item">
                        <span class="stat-val">@v.Preguntas.Count</span>
                        <span class="stat-lbl">Preguntas</span>
                    </div>
                    @if (v.DriveFolderId != null)
                    {
                        <div class="stat-item" style="margin-left: auto;">
                            <span class="stat-val" style="color: var(--primary-glow);"><i class="fa-brands fa-google-drive"></i></span>
                            <span class="stat-lbl">Sincronizado</span>
                        </div>
                    }
                </div>

                <a href="@Url.Action("Detail", "Examen", new { id = v.Id })" class="btn btn-secondary" style="width: 100%;">
                    Gestionar Versión <i class="fa-solid fa-arrow-right" style="margin-left: 6px; font-size: 12px;"></i>
                </a>
            </div>
        }
    </div>
}

<!-- MODAL ADD VERSION -->
<div class="modal-overlay" id="add-version-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Nueva Versión de Examen</h3>
            <button type="button" class="modal-close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="create-version-form" onsubmit="submitForm(event)" action="@Url.Action("CreateVersion", "Examen")" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="unidadId" value="@Model.Id" />
            
            <div class="form-group">
                <label for="nombreVersion">Nombre de la Versión</label>
                <input type="text" id="nombreVersion" name="nombreVersion" class="form-input" placeholder="Ej: Fila A" required />
            </div>

            <div class="form-group">
                <label style="display:block; margin-bottom: 8px;">Seleccionar Archivo PDF (Plantilla del examen)</label>
                <label for="pdfFile" class="file-upload-custom">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                    <span id="file-name-display" style="font-weight: 500;">Haz clic para buscar un archivo .pdf</span>
                </label>
                <input type="file" id="pdfFile" name="pdfFile" accept=".pdf" style="display: none;" required onchange="updateFileName(this)" />
            </div>

            <div class="form-group" style="margin-top: 20px;">
                <label style="display:block; margin-bottom: 8px;">Tipo de Archivo PDF</label>
                <div style="display: flex; gap: 20px; background: rgba(128, 128, 128, 0.05); padding: 15px; border-radius: 8px; border: 1px solid rgba(128, 128, 128, 0.1);">
                    <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; color: var(--text-color); flex: 1;">
                        <input type="radio" name="tipoExamen" value="vacio" required onchange="updateSubmitButtonState()" style="margin-top: 4px;" />
                        <div>
                            <span style="font-weight: 600; display: block; color: var(--text-color);">Examen Vacío</span>
                            <small style="color: var(--text-muted); font-size: 12px;">La IA detectará las preguntas. Las respuestas las rellenarás tú luego.</small>
                        </div>
                    </label>
                    <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; color: var(--text-color); flex: 1;">
                        <input type="radio" name="tipoExamen" value="resuelto" required onchange="updateSubmitButtonState()" style="margin-top: 4px;" />
                        <div>
                            <span style="font-weight: 600; display: block; color: var(--text-color);">Examen Resuelto</span>
                            <small style="color: var(--text-muted); font-size: 12px;">La IA extraerá las preguntas Y las respuestas marcadas.</small>
                        </div>
                    </label>
                </div>
            </div>

            <div id="modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="submit-btn" disabled>
                    <span>Crear Versión</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDIT VERSION -->
<div class="modal-overlay" id="edit-version-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Renombrar Versión</h3>
            <button class="modal-close" onclick="closeEditModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="edit-version-form" onsubmit="submitEditForm(event)">
            <input type="hidden" id="edit-id" />
            <div class="form-group">
                <label for="edit-nombre">Nuevo Nombre</label>
                <input type="text" id="edit-nombre" class="form-input" required />
            </div>

            <div id="edit-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="edit-submit-btn">
                    <span>Guardar Cambios</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL DELETE VERSION -->
<div class="modal-overlay" id="delete-version-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Eliminar Versión</h3>
            <button class="modal-close" onclick="closeDeleteModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <p style="margin-bottom: 20px; font-size: 15px; color: var(--text-muted);">
            ¿Estás seguro que deseas eliminar la versión <strong id="delete-version-nombre" style="color: var(--text-color);"></strong>? <br><br>
            <span style="color: #ff5252;"><i class="fa-solid fa-triangle-exclamation"></i> Advertencia:</span> Esto eliminará permanentemente la plantilla del examen, sus preguntas y todas las calificaciones de los alumnos para esta versión.
        </p>
        <form id="delete-version-form" onsubmit="submitDeleteForm(event)">
            <input type="hidden" id="delete-id" />
            <div id="delete-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>
            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 10px;">
                <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="delete-submit-btn" style="background: #ff5252; box-shadow: 0 4px 15px 0 rgba(255, 82, 82, 0.4); border: none;">
                    <span>Sí, Eliminar</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- LOADING OVERLAYS -->
<div class="modal-overlay" id="loading-overlay">
    <div class="modal-box" style="text-align: center; width: 300px; padding: 40px 20px;">
        <i class="fa-solid fa-spinner fa-spin" style="font-size: 48px; color: var(--accent-color); margin-bottom: 20px;"></i>
        <h3 id="loading-text">Procesando...</h3>
        <p style="font-size: 12px; color: var(--text-muted); margin-top: 10px;">Por favor no cierres ni recargues la página.</p>
    </div>
</div>

<!-- MODAL REVISION IA (60/40) -->
@if (TempData["ShowReviewModal"] != null && (bool)TempData["ShowReviewModal"] && ViewBag.PreguntasIA != null)
{
    var preguntas = (List<SCIBM.Models.Pregunta>)ViewBag.PreguntasIA;
    
    <div class="modal-overlay active" id="review-ia-modal">
        <div class="modal-box" style="width: 90%; max-width: 1200px; height: 90vh; display: flex; flex-direction: column; padding: 30px;">
            <div class="modal-header">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <h3>Revisión de Examen — IA</h3>
                    <span style="background: rgba(82, 196, 255, 0.2); color: #52c4ff; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 500;">
                        @preguntas.Count(p => !p.PreguntaPadreId.HasValue) secciones principales detectadas
                    </span>
                    <span id="total-puntaje-badge" style="background: rgba(255, 193, 7, 0.2); color: #ffc107; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 500; transition: all 0.3s ease;">
                        Nota total: 0 pts
                    </span>
                </div>
                <button type="button" class="modal-close" onclick="closeReviewModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <form action="@Url.Action("ConfirmarSolucionario", "Examen")" method="POST" id="review-form" style="flex: 1; display: flex; flex-direction: column; overflow: hidden; margin-top: 20px;" onsubmit="return validateReviewForm()">
                @Html.AntiForgeryToken()
                <input type="hidden" name="examenId" value="@ViewBag.ExamenIdIA" />
                
                <div style="flex: 1; overflow-y: auto; padding-right: 15px; margin-bottom: 20px;" class="custom-scrollbar">
                    <table style="width: 100%; border-collapse: separate; border-spacing: 0 8px; color: var(--text-color);">
                        <thead>
                            <tr style="text-align: left;">
                                <th style="padding: 0 15px 10px 15px; width: 60%; color: var(--text-muted); font-weight: 500;">Pregunta / Enunciado</th>
                                <th style="padding: 0 15px 10px 15px; width: 40%; color: var(--text-muted); font-weight: 500;">Respuesta Correcta y Puntaje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int index = 0; }
                            @foreach (var p in preguntas)
                            {
                                bool isPadre = !p.PreguntaPadreId.HasValue;
                                string indent = isPadre ? "0" : "30px";
                                string bgRow = isPadre ? "rgba(128, 128, 128, 0.03)" : "var(--glass-bg)";
                                string boldStr = isPadre ? "font-weight: bold; color: var(--text-color);" : "";
                                string numPrefix = isPadre ? $"{p.NumeroPregunta}." : $"{p.Inciso})";

                                <tr style="background: @bgRow; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                                    <td style="padding: 15px; padding-left: calc(15px + @indent); border-radius: 8px 0 0 8px; border: 1px solid var(--glass-border); border-right: none;">
                                        <input type="hidden" name="preguntasEditadas[@index].Id" value="@p.Id" />
                                        <input type="hidden" name="preguntasEditadas[@index].Tipo" value="@p.Tipo" />
                                        
                                        <div style="display: flex; align-items: flex-start; gap: 12px;">
                                            <span style="color: var(--primary-glow); font-size: 16px; @boldStr; margin-top: 8px;">@numPrefix</span>
                                            <textarea name="preguntasEditadas[@index].Enunciado" class="form-input" style="flex: 1; resize: vertical; min-height: 40px; border: none; background: transparent; padding: 8px; @boldStr">@p.Enunciado</textarea>
                                        </div>
                                        @if (!isPadre) {
                                            <div style="margin-top: 8px; margin-left: 30px;">
                                                <span style="font-size: 11px; padding: 3px 8px; background: rgba(255,255,255,0.1); border-radius: 4px; color: var(--text-muted);">
                                                    @p.Tipo
                                                </span>
                                            </div>
                                        }
                                    </td>
                                    
                                    <td style="padding: 15px; border-radius: 0 8px 8px 0; border: 1px solid var(--glass-border); border-left: none; vertical-align: top;">
                                        @if (isPadre)
                                        {
                                            <div style="padding: 10px; color: var(--text-muted); font-size: 13px; font-style: italic;">
                                                Instrucciones de sección (Sin respuesta)
                                            </div>
                                            <input type="hidden" name="preguntasEditadas[@index].Puntaje" value="0" />
                                            <input type="hidden" name="preguntasEditadas[@index].RespuestaCorrecta" value="" />
                                        }
                                        else
                                        {
                                            <div style="display: flex; gap: 15px; align-items: flex-start;">
                                                <div style="flex: 1;">
                                                    @if (p.Tipo == "OpcionMultiple" && !string.IsNullOrEmpty(p.OpcionesJson))
                                                    {
                                                        var opciones = Newtonsoft.Json.JsonConvert.DeserializeObject<List<SCIBM.Controllers.OpcionTemp>>(p.OpcionesJson);
                                                        <select name="preguntasEditadas[@index].RespuestaCorrecta" class="form-input review-answer" data-required="true" style="width: 100%;">
                                                            <option value="">-- Seleccionar --</option>
                                                            @foreach (var op in opciones)
                                                            {
                                                                <option value="@op.label" @(p.RespuestaCorrecta?.ToUpper() == op.label.ToUpper() ? "selected" : "")>@op.label) @op.text</option>
                                                            }
                                                        </select>
                                                    }
                                                    else if (p.Tipo == "VerdaderoFalso")
                                                    {
                                                        <select name="preguntasEditadas[@index].RespuestaCorrecta" class="form-input review-answer" data-required="true" style="width: 100%;">
                                                            <option value="">-- Seleccionar --</option>
                                                            <option value="V" @(p.RespuestaCorrecta?.ToUpper() == "V" ? "selected" : "")>Verdadero (V)</option>
                                                            <option value="F" @(p.RespuestaCorrecta?.ToUpper() == "F" ? "selected" : "")>Falso (F)</option>
                                                        </select>
                                                    }
                                                    else if (p.Tipo == "RespuestaAbierta")
                                                    {
                                                        <textarea name="preguntasEditadas[@index].RespuestaCorrecta" class="form-input" style="width: 100%; height: 42px; resize: vertical;" placeholder="(Opcional) Criterios de evaluación">@p.RespuestaCorrecta</textarea>
                                                    }
                                                    else
                                                    {
                                                        <input type="text" name="preguntasEditadas[@index].RespuestaCorrecta" value="@p.RespuestaCorrecta" class="form-input review-answer" data-required="true" style="width: 100%;" placeholder="Ingrese la respuesta correcta" />
                                                    }
                                                </div>
                                                <div style="width: 90px; flex-shrink: 0;">
                                                    <div style="position: relative;">
                                                        <input type="number" step="0.1" name="preguntasEditadas[@index].Puntaje" value="@p.Puntaje.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="form-input puntaje-input" style="width: 100%; padding-right: 35px; text-align: right;" title="Puntaje" oninput="updateTotalPuntaje()" />
                                                        <span style="position: absolute; right: 12px; top: 12px; color: var(--text-muted); font-size: 12px; pointer-events: none;">pts</span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>

                <div id="review-error" style="color: #ff5252; font-size: 14px; margin-bottom: 15px; display: none; text-align: center; background: rgba(255, 82, 82, 0.1); padding: 10px; border-radius: 8px;">
                    <i class="fa-solid fa-triangle-exclamation"></i> Por favor, rellena todas las respuestas obligatorias (marcadas en rojo).
                </div>

                <div style="display: flex; justify-content: flex-end; gap: 15px; padding-top: 20px; border-top: 1px solid var(--glass-border);">
                    <button type="button" class="btn btn-secondary" onclick="closeReviewModal()">Cerrar sin guardar</button>
                    <button type="submit" class="btn btn-primary" id="confirm-review-btn">
                        <span><i class="fa-solid fa-check"></i> Confirmar y Guardar</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section scripts {
    <script>
        function updateTotalPuntaje() {
            var inputs = document.querySelectorAll('.puntaje-input');
            var total = 0;
            inputs.forEach(function(input) {
                var val = parseFloat(input.value) || 0;
                total += val;
            });
            var badge = document.getElementById('total-puntaje-badge');
            if(badge) {
                // Remove trailing zeros, e.g., 20.0 -> 20
                badge.innerText = 'Nota total: ' + Number(total.toFixed(2)).toString() + ' pts';
                
                // Efecto visual al actualizar
                badge.style.transform = 'scale(1.05)';
                setTimeout(() => badge.style.transform = 'scale(1)', 150);
            }
        }

        // Llamar una vez al inicio si el modal existe
        if(document.getElementById('review-ia-modal')) {
            updateTotalPuntaje();
        }

        function openModal() {
            document.getElementById("add-version-modal").classList.add("active");
            document.getElementById("nombreVersion").focus();
        }

        function closeModal() {
            document.getElementById("add-version-modal").classList.remove("active");
            document.getElementById("create-version-form").reset();
            document.getElementById("modal-error").style.display = "none";
            document.getElementById("file-name-display").innerText = "Haz clic para buscar un archivo .pdf";
            document.getElementById("file-name-display").style.color = "";
            document.getElementById("submit-btn").disabled = true;
        }

        function updateFileName(input) {
            var display = document.getElementById("file-name-display");
            if (input.files && input.files.length > 0) {
                display.innerText = input.files[0].name;
                display.style.color = "var(--primary-glow)";
            } else {
                display.innerText = "Haz clic para buscar un archivo .pdf";
                display.style.color = "";
            }
            updateSubmitButtonState();
        }

        function updateSubmitButtonState() {
            var fileInput = document.getElementById("pdfFile");
            var submitBtn = document.getElementById("submit-btn");
            var tipoExamen = document.querySelector('input[name="tipoExamen"]:checked');
            
            if (fileInput.files && fileInput.files.length > 0 && tipoExamen) {
                submitBtn.disabled = false;
            } else {
                submitBtn.disabled = true;
            }
        }

        function closeReviewModal() {
            document.getElementById('review-ia-modal').classList.remove('active');
        }

        function validateReviewForm() {
            let isValid = true;
            const requiredAnswers = document.querySelectorAll('.review-answer[data-required="true"]');
            
            requiredAnswers.forEach(el => {
                if (!el.value || el.value.trim() === '') {
                    isValid = false;
                    el.style.border = '1px solid #ff5252';
                    el.style.backgroundColor = 'rgba(255, 82, 82, 0.05)';
                } else {
                    el.style.border = '';
                    el.style.backgroundColor = '';
                }
            });
            
            const errorMsg = document.getElementById('review-error');
            if (!isValid) {
                errorMsg.style.display = 'block';
            } else {
                errorMsg.style.display = 'none';
                document.getElementById('confirm-review-btn').innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Guardando...';
                document.getElementById('confirm-review-btn').disabled = true;
            }
            
            return isValid;
        }

        document.addEventListener('DOMContentLoaded', () => {
            const requiredAnswers = document.querySelectorAll('.review-answer[data-required="true"]');
            requiredAnswers.forEach(el => {
                el.addEventListener('change', () => {
                    if (el.value.trim() !== '') {
                        el.style.border = '';
                        el.style.backgroundColor = '';
                    }
                });
                el.addEventListener('input', () => {
                    if (el.value.trim() !== '') {
                        el.style.border = '';
                        el.style.backgroundColor = '';
                    }
                });
            });
        });

        function openEditModal(id, nombre) {
            document.getElementById("edit-id").value = id;
            document.getElementById("edit-nombre").value = nombre;
            document.getElementById("edit-version-modal").classList.add("active");
            document.getElementById("edit-nombre").focus();
        }

        function closeEditModal() {
            document.getElementById("edit-version-modal").classList.remove("active");
            document.getElementById("edit-version-form").reset();
            document.getElementById("edit-modal-error").style.display = "none";
        }

        function submitEditForm(e) {
            e.preventDefault();
            
            var submitBtn = document.getElementById("edit-submit-btn");
            var originalHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Guardando...';

            var id = document.getElementById("edit-id").value;
            var newName = document.getElementById("edit-nombre").value;

            fetch('@Url.Action("Rename", "Examen")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + encodeURIComponent(id) + '&newName=' + encodeURIComponent(newName)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("edit-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al renombrar.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("edit-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

        // DELETE MODAL
        function openDeleteModal(id, nombre) {
            document.getElementById("delete-id").value = id;
            document.getElementById("delete-version-nombre").innerText = nombre;
            document.getElementById("delete-version-modal").classList.add("active");
        }

        function closeDeleteModal() {
            document.getElementById("delete-version-modal").classList.remove("active");
            document.getElementById("delete-modal-error").style.display = "none";
        }

        function submitDeleteForm(e) {
            e.preventDefault();
            
            var submitBtn = document.getElementById("delete-submit-btn");
            var originalHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Eliminando...';

            var id = document.getElementById("delete-id").value;

            fetch('@Url.Action("Delete", "Examen")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + encodeURIComponent(id)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("delete-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al eliminar.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("delete-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

        function submitForm(e) {
            var submitBtn = document.getElementById("submit-btn");
            document.getElementById("loading-text").innerText = "Creando versión y subiendo archivos...";
            document.getElementById("loading-overlay").classList.add("active");
            submitBtn.disabled = true;
        }
    </script>
}
