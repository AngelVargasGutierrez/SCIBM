                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + encodeURIComponent(id)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("delete-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al eliminar.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("delete-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

        // Auto-fade alerts after 3 seconds
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                alert.style.transition = "opacity 0.8s ease-out, margin-top 0.8s ease-out, height 0.8s ease-out, padding 0.8s ease-out, margin-bottom 0.8s ease-out";
                alert.style.opacity = "0";
                alert.style.height = "0";
                alert.style.paddingTop = "0";
                alert.style.paddingBottom = "0";
                alert.style.marginTop = "0";
                alert.style.marginBottom = "0";
                alert.style.overflow = "hidden";
                alert.style.border = "none";
                setTimeout(() => alert.remove(), 800);
            });
        }, 3000);
    </script>
