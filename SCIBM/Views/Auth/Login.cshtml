@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - SCIBM UPT</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --upt-blue: #1A4B8D;
            --upt-gold: #CD9B37;
            --bg-color: #ffffff;
            --text-color: #333333;
            --text-muted: #666666;
            --box-shadow: 0 10px 30px rgba(26, 75, 141, 0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Outfit', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        /* Decorative background elements */
        .bg-shape {
            position: absolute;
            z-index: 0;
            opacity: 0.05;
        }
        .shape-1 {
            top: -100px;
            left: -100px;
            width: 400px;
            height: 400px;
            background-color: var(--upt-blue);
            border-radius: 50%;
        }
        .shape-2 {
            bottom: -150px;
            right: -100px;
            width: 500px;
            height: 500px;
            background-color: var(--upt-gold);
            border-radius: 50%;
        }

        /* HEADER / TITLE */
        .header-area {
            text-align: center;
            margin-bottom: 30px;
            z-index: 10;
            animation: fadeInDown 0.8s ease-out;
        }
        .header-area h1 {
            font-size: 42px;
            font-weight: 700;
            color: var(--upt-blue);
            letter-spacing: 1px;
        }
        .header-area p {
            font-size: 16px;
            color: var(--text-muted);
            margin-top: 8px;
            max-width: 400px;
            line-height: 1.5;
        }

        /* LOGIN CONTAINER */
        .login-box {
            width: 450px;
            max-width: 90%;
            background: #ffffff;
            border: 2px solid var(--upt-gold);
            border-radius: 16px;
            padding: 40px;
            box-shadow: var(--box-shadow);
            z-index: 10;
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 25px;
            animation: fadeInUp 0.8s ease-out;
        }

        @@keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* GOOGLE BUTTON */
        .google-btn {
            background: #ffffff;
            color: #444;
            border: 1px solid #ddd;
            padding: 14px 24px;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }
        .google-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26, 75, 141, 0.15);
            border-color: var(--upt-blue);
        }
        .google-btn img {
            width: 24px;
            height: 24px;
        }

        /* DOMAIN INFO */
        .domain-info {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.5;
            background: rgba(26, 75, 141, 0.03);
            padding: 12px;
            border-radius: 10px;
            border: 1px dashed rgba(26, 75, 141, 0.2);
        }
        .domain-info strong {
            color: var(--upt-blue);
        }

        /* ERROR ALERTS */
        .error-alert {
            background: rgba(205, 155, 55, 0.1);
            border: 1px solid var(--upt-gold);
            color: #a87b20;
            padding: 14px 16px;
            border-radius: 10px;
            font-size: 14px;
            text-align: left;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            line-height: 1.5;
        }
        .error-alert i {
            margin-top: 2px;
            font-size: 18px;
            color: var(--upt-gold);
        }
    </style>
</head>
<body>

    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>

    <div class="header-area">
        <h1>SCIBM UPT</h1>
        <p>Sistema de Escaneo y Calificación de Exámenes</p>
    </div>

    <!-- MAIN LOGIN CARD -->
    <div class="login-box">
        
        <!-- ERROR ALERT IF PRESENT -->
        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="error-alert">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@ViewBag.Error</span>
            </div>
        }

        <!-- GOOGLE OAUTH BUTTON -->
        <a href="@Url.Action("GoogleLogin", "Auth")" class="google-btn">
            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google Logo" />
            <span>Iniciar sesión con Google</span>
        </a>

        <!-- DOMAIN POLICY -->
        <div class="domain-info">
            <i class="fa-solid fa-circle-info" style="margin-right: 4px; color: var(--upt-gold);"></i>
            Por favor, asegúrate de ingresar con una cuenta institucional terminada en <strong>@@virtual.upt.pe</strong> o <strong>@@upt.pe</strong>.
        </div>

    </div>

</body>
</html>
