@model SCIBM.Models.Curso
@{
    ViewBag.Title = Model.Nombre;
    ViewBag.Subtitle = $"Código del Curso: {Model.Codigo.ToUpper()}";
}

<style>
    .units-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
    }

    .unit-card {
        background: rgba(128, 128, 128, 0.05);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 16px;
        transition: border-color 0.2s;
    }
    .unit-card:hover {
        border-color: rgba(100, 223, 223, 0.25);
        background: rgba(128, 128, 128, 0.08);
    }
    .unit-info {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
    .unit-badge {
        font-size: 14px;
        font-weight: 700;
        background: var(--accent-color);
        color: #0b132b;
        padding: 6px 12px;
        border-radius: 6px;
        text-transform: uppercase;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--glass-border);
    }
    .panel-header h2 {
        font-size: 18px;
        font-weight: 600;
    }

    .edit-btn {
        color: var(--text-color);
        background: none;
        border: none;
        font-size: 14px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.2s ease;
        padding: 4px;
    }
    .edit-btn:hover {
        color: var(--accent-color);
        opacity: 1;
        transform: scale(1.1);
    }
    .delete-btn {
        color: var(--text-color);
        background: none;
        border: none;
        font-size: 14px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.2s ease;
        padding: 4px;
    }
    .delete-btn:hover {
        color: #ff5252;
        opacity: 1;
        transform: scale(1.1);
    }
    
    /* BREADCRUMB */
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 15px;
        font-weight: 500;
        color: var(--text-muted);
    }
    .breadcrumb a {
        color: var(--text-color);
        text-decoration: none;
        transition: color 0.2s;
    }
    .breadcrumb a:hover {
        color: var(--primary-glow);
    }
    .breadcrumb-separator {
        color: rgba(255, 255, 255, 0.2);
        font-size: 11px;
    }
    .breadcrumb-current {
        color: var(--primary-glow);
    }
</style>

<div class="action-bar">
    <div class="breadcrumb">
        <a href="@Url.Action("Index", "Ciclo")"><i class="fa-solid fa-calendar-days" style="margin-right: 6px;"></i> Ciclos</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <a href="@Url.Action("Index", "Curso", new { cicloId = Model.CicloAcademicoId })">@Model.CicloAcademico.Nombre</a>
        <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
        <span class="breadcrumb-current">@Model.Nombre</span>
    </div>
</div>

<div class="glass-card">
    <div class="panel-header">
        <h2>Secciones del Curso</h2>
        <button class="btn btn-primary" onclick="openSeccionModal()">
            <i class="fa-solid fa-plus"></i> Nueva Sección
        </button>
    </div>

    @if (!Model.Secciones.Any())
    {
        <div style="text-align: center; padding: 80px 20px; color: var(--text-muted);">
            <i class="fa-solid fa-folder-open" style="font-size: 48px; opacity: 0.3; margin-bottom: 16px; display: block;"></i>
            <h3>No hay secciones creadas</h3>
            <p style="font-size: 14px; margin-top: 6px;">Agrega una sección para comenzar.</p>
        </div>
    }
    else
    {
        <div class="units-grid">
            @foreach (var sec in Model.Secciones.OrderBy(s => s.Nombre))
            {
                <div class="unit-card">
                    <div>
                        <div class="unit-info">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span class="unit-badge">@sec.Nombre</span>
                                <div style="display: flex; gap: 4px;">
                                    <button class="edit-btn" onclick="openEditModal('@sec.Id', '@sec.Nombre')" title="Renombrar">
                                        <i class="fa-solid fa-pencil"></i>
                                    </button>
                                    <button class="delete-btn" onclick="openDeleteModal('@sec.Id', '@sec.Nombre')" title="Eliminar">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                            </div>
                            @if (sec.DriveFolderId != null)
                            {
                                <span style="font-size: 13px; color: var(--text-muted);" title="Sincronizado con Google Drive"><i class="fa-brands fa-google-drive"></i></span>
                            }
                        </div>
                    </div>
                    <div>
                        <a href="@Url.Action("Detail", "Seccion", new { id = sec.Id })" class="btn btn-secondary" style="width: 100%; font-size: 13px; padding: 8px 12px;">
                            Gestionar Sección <i class="fa-solid fa-arrow-right" style="margin-left: 6px; font-size: 11px;"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- MODAL ADD SECCION -->
<div class="modal-overlay" id="add-seccion-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Nueva Sección</h3>
            <button class="modal-close" onclick="closeSeccionModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="create-seccion-form" onsubmit="submitSeccionForm(event)">
            <input type="hidden" id="seccionCursoId" name="cursoId" value="@Model.Id" />
            
            <div class="form-group">
                <label for="nombreSeccion">Nombre de la Sección</label>
                <input type="text" id="nombreSeccion" name="nombreSeccion" class="form-input" placeholder="Ej: Sección A, Turno Mañana" required />
            </div>

            <div id="seccion-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeSeccionModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="seccion-submit-btn">
                    <span>Guardar y Crear Carpeta en Drive</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDIT SECCION -->
<div class="modal-overlay" id="edit-seccion-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Renombrar Sección</h3>
            <button class="modal-close" onclick="closeEditModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        
        <form id="edit-seccion-form" onsubmit="submitEditForm(event)">
            <input type="hidden" id="edit-id" />
            <div class="form-group">
                <label for="edit-nombre">Nuevo Nombre</label>
                <input type="text" id="edit-nombre" class="form-input" required />
            </div>

            <div id="edit-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px;">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="edit-submit-btn">
                    <span>Guardar Cambios</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL DELETE SECCION -->
<div class="modal-overlay" id="delete-seccion-modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Eliminar Sección</h3>
            <button class="modal-close" onclick="closeDeleteModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <p style="margin-bottom: 20px; font-size: 15px; color: var(--text-muted);">
            ¿Estás seguro que deseas eliminar la sección <strong id="delete-seccion-nombre" style="color: var(--text-color);"></strong>? <br><br>
            <span style="color: #ff5252;"><i class="fa-solid fa-triangle-exclamation"></i> Advertencia:</span> Esto eliminará permanentemente todos los alumnos matriculados, unidades y exámenes asociados a esta sección.
        </p>
        <form id="delete-seccion-form" onsubmit="submitDeleteForm(event)">
            <input type="hidden" id="delete-id" />
            <div id="delete-modal-error" style="color: #ff5252; font-size: 13px; margin-bottom: 15px; display: none;"></div>
            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 10px;">
                <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary" id="delete-submit-btn" style="background: #ff5252; box-shadow: 0 4px 15px 0 rgba(255, 82, 82, 0.4); border: none;">
                    <span>Sí, Eliminar</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section scripts {
    <script>
        function openSeccionModal() {
            document.getElementById("add-seccion-modal").classList.add("active");
            document.getElementById("nombreSeccion").focus();
        }
        function closeSeccionModal() {
            document.getElementById("add-seccion-modal").classList.remove("active");
            document.getElementById("create-seccion-form").reset();
            document.getElementById("seccion-modal-error").style.display = "none";
        }

        function openEditModal(id, nombre) {
            document.getElementById("edit-id").value = id;
            document.getElementById("edit-nombre").value = nombre;
            document.getElementById("edit-seccion-modal").classList.add("active");
            document.getElementById("edit-nombre").focus();
        }

        function closeEditModal() {
            document.getElementById("edit-seccion-modal").classList.remove("active");
            document.getElementById("edit-seccion-form").reset();
            document.getElementById("edit-modal-error").style.display = "none";
        }

        function submitEditForm(e) {
            e.preventDefault();
            
            var submitBtn = document.getElementById("edit-submit-btn");
            var originalHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Guardando...';

            var id = document.getElementById("edit-id").value;
            var newName = document.getElementById("edit-nombre").value;

            fetch('@Url.Action("Rename", "Seccion")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + encodeURIComponent(id) + '&newName=' + encodeURIComponent(newName)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("edit-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al renombrar.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("edit-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

        function openDeleteModal(id, nombre) {
            document.getElementById("delete-id").value = id;
            document.getElementById("delete-seccion-nombre").innerText = nombre;
            document.getElementById("delete-seccion-modal").classList.add("active");
        }

        function closeDeleteModal() {
            document.getElementById("delete-seccion-modal").classList.remove("active");
            document.getElementById("delete-modal-error").style.display = "none";
        }

        function submitDeleteForm(e) {
            e.preventDefault();
            
            var submitBtn = document.getElementById("delete-submit-btn");
            var originalHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Eliminando...';

            var id = document.getElementById("delete-id").value;

            fetch('@Url.Action("Delete", "Seccion")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + encodeURIComponent(id)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("delete-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al eliminar.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("delete-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }

        function submitSeccionForm(e) {
            e.preventDefault();
            
            var submitBtn = document.getElementById("seccion-submit-btn");
            var originalHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creando...';

            var cursoId = document.getElementById("seccionCursoId").value;
            var nombreSeccion = document.getElementById("nombreSeccion").value;

            fetch('@Url.Action("Create", "Seccion")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'cursoId=' + encodeURIComponent(cursoId) + '&nombreSeccion=' + encodeURIComponent(nombreSeccion)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    var errDiv = document.getElementById("seccion-modal-error");
                    errDiv.innerText = data.message || "Ocurrió un error al crear la sección.";
                    errDiv.style.display = "block";
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                var errDiv = document.getElementById("seccion-modal-error");
                errDiv.innerText = "Error de conexión con el servidor.";
                errDiv.style.display = "block";
            });
        }
    </script>
}
